@{
    ViewData["Title"] = "About";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Hero Section -->
<section class="hero-section py-20 mt-16">
    <div class="custom-container py-12">
        <div class="flex items-center justify-center">
            <div class="w-full lg:w-2/3 mx-auto text-center">
                <h1 class="text-4xl lg:text-5xl font-bold text-white mb-6">About Smart Task Tracker</h1>
                <p class="text-xl text-white mb-6">
                    Empowering teams and individuals to achieve more by simplifying task management and boosting productivity.
                </p>
            </div>
        </div>
    </div>
</section>

<!-- Mission Section -->
<section class="py-16">
    <div class="custom-container">
        <div class="flex justify-center">
            <div class="w-full lg:w-2/3">
                <h2 class="text-3xl font-bold text-gray-800 mb-6">Our Mission</h2>
                <p class="text-gray-600 text-lg mb-6">
                    At Smart Task Tracker, we believe that effective task management is the foundation of success.
                    Our mission is to provide a simple, elegant, and powerful tool that helps individuals and teams
                    organize their work, stay focused, and accomplish their goals.
                </p>
                <p class="text-gray-600 text-lg">
                    We're committed to continuous innovation, user-centric design, and delivering exceptional value
                    to our community of users worldwide.
                </p>
            </div>
        </div>
    </div>
</section>

<!-- Features List -->
<section class="py-16 bg-light">
    <div class="custom-container">
        <h2 class="text-3xl font-bold text-gray-800 text-center mb-12">Key Features</h2>
        <div class="flex justify-center">
            <div class="w-full lg:w-2/3">
                <div class="space-y-4">
                    <div class="flex items-center">
                        <i class="fas fa-check text-green-500 mr-4 text-lg"></i>
                        <span class="text-gray-700 text-lg">Smart Priority Calculation Algorithm</span>
                    </div>
                    <div class="flex items-center">
                        <i class="fas fa-check text-green-500 mr-4 text-lg"></i>
                        <span class="text-gray-700 text-lg">Productivity Analytics and Insights</span>
                    </div>
                    <div class="flex items-center">
                        <i class="fas fa-check text-green-500 mr-4 text-lg"></i>
                        <span class="text-gray-700 text-lg">Role-based User Management</span>
                    </div>
                    <div class="flex items-center">
                        <i class="fas fa-check text-green-500 mr-4 text-lg"></i>
                        <span class="text-gray-700 text-lg">Real-time Progress Tracking</span>
                    </div>
                    <div class="flex items-center">
                        <i class="fas fa-check text-green-500 mr-4 text-lg"></i>
                        <span class="text-gray-700 text-lg">Automated Notifications</span>
                    </div>
                    <div class="flex items-center">
                        <i class="fas fa-check text-green-500 mr-4 text-lg"></i>
                        <span class="text-gray-700 text-lg">Secure User Authentication</span>
                    </div>
                    <div class="flex items-center">
                        <i class="fas fa-check text-green-500 mr-4 text-lg"></i>
                        <span class="text-gray-700 text-lg">Responsive Design for All Devices</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Technology Stack -->
<section class="py-16">
    <div class="custom-container">
        <h2 class="text-3xl font-bold text-gray-800 text-center mb-12">Technology Stack</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <div class="custom-card p-6 text-center">
                <h5 class="font-bold text-blue-600 text-xl mb-2">ASP.NET Core Web API</h5>
                <p class="text-gray-600">Backend framework</p>
            </div>
            <div class="custom-card p-6 text-center">
                <h5 class="font-bold text-blue-600 text-xl mb-2">Entity Framework Core</h5>
                <p class="text-gray-600">Database ORM</p>
            </div>
            <div class="custom-card p-6 text-center">
                <h5 class="font-bold text-blue-600 text-xl mb-2">SQL Server</h5>
                <p class="text-gray-600">Database management</p>
            </div>
            <div class="custom-card p-6 text-center">
                <h5 class="font-bold text-blue-600 text-xl mb-2">HTML/CSS/JavaScript</h5>
                <p class="text-gray-600">Frontend development</p>
            </div>
            <div class="custom-card p-6 text-center">
                <h5 class="font-bold text-blue-600 text-xl mb-2">Tailwind CSS</h5>
                <p class="text-gray-600">Frontend styling</p>
            </div>
            <div class="custom-card p-6 text-center">
                <h5 class="font-bold text-blue-600 text-xl mb-2">C#</h5>
                <p class="text-gray-600">Programming language</p>
            </div>
        </div>
    </div>
</section>

<!-- Team Members -->
<section class="py-16 bg-light">
    <div class="custom-container">
        <h2 class="text-3xl font-bold text-gray-800 text-center mb-12">Development Team</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 max-w-5xl mx-auto">
            <!-- Sudarshan Sharma -->
            <div class="custom-card p-8 text-center">
                <div class="team-image-container mb-6 mx-auto">
                    <img src="~/img/sudarshan.jpg" alt="Sudarshan Sharma" class="team-image rounded-full shadow-sm" />
                </div>
                <h5 class="font-bold text-gray-800 text-xl mb-2">Sudarshan Sharma</h5>
                <p class="text-gray-600 mb-4">.NET Developer</p>
                <div class="social-links mt-4 flex justify-center space-x-6">
                    <a href="https://github.com/Sudarshan21git" class="text-gray-600 hover:text-purple-600 text-2xl">
                        <i class="fab fa-github"></i>
                    </a>
                    <a href="https://www.linkedin.com/in/sudarshan-sharma21/" class="text-gray-600 hover:text-purple-600 text-2xl">
                        <i class="fab fa-linkedin"></i>
                    </a>
                </div>
            </div>

            <!-- Rohit Shrestha -->
            <div class="custom-card p-8 text-center">
                <div class="team-image-container mb-6 mx-auto">
                    <div class="team-image-container mb-6 mx-auto">
                        <img src="~/img/rohit.jpg"alt="Rohit" class="team-image rounded-full shadow-sm" />
                    </div>
                </div>
                <h5 class="font-bold text-gray-800 text-xl mb-2">Rohit Shrestha</h5>
                <p class="text-gray-600 mb-4">Mentor / Project Supervisor</p>
                <div class="social-links mt-4 flex justify-center space-x-6">
                    <a href="https://www.linkedin.com/in/rohit-cstha/" class="text-gray-600 hover:text-purple-600 text-2xl">
                        <i class="fab fa-linkedin"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Contact Section -->
<section class="contact-section py-16">
    <div class="custom-container">
        <div class="text-center">
            <h2 class="text-3xl font-bold text-white mb-6">Ready to Get Started?</h2>
            <p class="text-white text-xl mb-8">
                Join our growing community of productive users.
            </p>
            <a asp-controller="Account" asp-action="Register" class="custom-btn custom-btn-light text-lg px-8 py-3 rounded-lg font-medium inline-block">
                Get Started Now <i class="fas fa-arrow-right ml-2"></i>
            </a>
        </div>
    </div>
</section>