@model DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";
}

<div class="max-w-7xl mx-auto">
    <!-- Welcome Header -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
        <div class="lg:col-span-2 rounded-2xl bg-gradient-to-r from-slate-900 via-slate-800 to-slate-700 text-white p-8 shadow-xl">
            <div class="inline-flex items-center gap-2 rounded-full bg-white/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] text-slate-200 mb-4">
                <span>@Model.UserRole</span>
                <span class="h-1 w-1 rounded-full bg-cyan-400"></span>
                <span>Personal dashboard</span>
            </div>
            <h1 class="text-3xl font-bold mb-3">Welcome back, @Model.UserName!</h1>
            <p class="text-slate-300 max-w-2xl">Track your work, plan your week, and keep an eye on what is due next.</p>
        </div>

        <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <h2 class="text-lg font-semibold text-slate-900 mb-4">Profile snapshot</h2>
            <div class="space-y-3 text-sm">
                <div class="flex items-center justify-between gap-4">
                    <span class="text-slate-500">Name</span>
                    <span class="font-medium text-slate-900 text-right">@Model.UserName</span>
                </div>
                <div class="flex items-center justify-between gap-4">
                    <span class="text-slate-500">Email</span>
                    <span class="font-medium text-slate-900 text-right break-all">@Model.UserEmail</span>
                </div>
                <div class="flex items-center justify-between gap-4">
                    <span class="text-slate-500">Role</span>
                    <span class="inline-flex rounded-full bg-blue-50 px-3 py-1 text-xs font-semibold text-blue-700">@Model.UserRole</span>
                </div>
            </div>
        </div>
    </div>

    @if (string.Equals(Model.UserRole, "User", StringComparison.OrdinalIgnoreCase))
    {
        <div class="mb-8 rounded-2xl border border-blue-200 bg-blue-50 px-5 py-4 shadow-sm">
            <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
                <div>
                    <p class="text-sm font-semibold text-blue-700">Knapsack ranking enabled</p>
                    <p class="text-sm text-blue-900/80">Individual tasks are reprioritized after each update, and the score is shown in the task rows below.</p>
                </div>
                <span class="inline-flex w-fit rounded-full bg-white px-3 py-1 text-xs font-semibold text-blue-700 shadow-sm">Score visible in task rows</span>
            </div>
        </div>
    }

    <!-- Statistics Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
        <div class="bg-blue-50 border border-blue-200 rounded-lg p-6 shadow-sm hover:shadow-md transition-shadow">
            <p class="text-sm font-medium text-gray-600 mb-2">Total Tasks</p>
            <p class="text-4xl font-bold text-blue-600" id="totalTasks">@Model.TotalTasks</p>
        </div>
        <div class="bg-green-50 border border-green-200 rounded-lg p-6 shadow-sm hover:shadow-md transition-shadow">
            <p class="text-sm font-medium text-gray-600 mb-2">Completed</p>
            <p class="text-4xl font-bold text-green-600" id="completedTasks">@Model.CompletedTasks</p>
        </div>
        <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-6 shadow-sm hover:shadow-md transition-shadow">
            <p class="text-sm font-medium text-gray-600 mb-2">Pending</p>
            <p class="text-4xl font-bold text-yellow-600" id="pendingTasks">@Model.PendingTasks</p>
        </div>
        <div class="bg-red-50 border border-red-200 rounded-lg p-6 shadow-sm hover:shadow-md transition-shadow">
            <p class="text-sm font-medium text-gray-600 mb-2">Overdue</p>
            <p class="text-4xl font-bold text-red-600" id="overdueTasks">@Model.OverdueTasks</p>
        </div>
    </div>

    <!-- Priority Summary -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
        <div class="rounded-xl border border-emerald-100 bg-emerald-50 p-5">
            <p class="text-sm font-medium text-emerald-700">Low priority</p>
            <p class="mt-2 text-3xl font-bold text-emerald-700">@Model.LowPriorityTasks</p>
        </div>
        <div class="rounded-xl border border-amber-100 bg-amber-50 p-5">
            <p class="text-sm font-medium text-amber-700">Medium priority</p>
            <p class="mt-2 text-3xl font-bold text-amber-700">@Model.MediumPriorityTasks</p>
        </div>
        <div class="rounded-xl border border-rose-100 bg-rose-50 p-5">
            <p class="text-sm font-medium text-rose-700">High priority</p>
            <p class="mt-2 text-3xl font-bold text-rose-700">@Model.HighPriorityTasks</p>
        </div>
    </div>

    @if (string.Equals(Model.UserRole, "User", StringComparison.OrdinalIgnoreCase))
    {
        <div class="mb-8 rounded-2xl border border-indigo-200 bg-gradient-to-br from-white via-indigo-50 to-cyan-50 p-6 shadow-sm">
            <div class="flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
                <div class="max-w-2xl">
                    <p class="text-sm font-semibold uppercase tracking-[0.2em] text-indigo-600">Daily planner</p>
                    <h2 class="mt-2 text-2xl font-bold text-slate-900">Generate today's schedule</h2>
                    <p class="mt-2 text-sm text-slate-600">Enter how much time you can work today. The planner uses each task's estimated minutes as the knapsack weight and the entropy score as the value, so the mix changes with your available time.</p>
                </div>
                <div class="flex flex-col gap-3 sm:flex-row lg:w-[28rem]">
                    <div class="flex-1">
                        <label class="mb-1 block text-xs font-semibold uppercase tracking-wide text-slate-500">Today's time budget</label>
                        <input id="dailyAvailableMinutes"
                               type="number"
                               min="1"
                               step="15"
                               value="240"
                               class="w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-200" />
                    </div>
                    <button onclick="generateDailySchedule()"
                            class="rounded-xl bg-slate-900 px-5 py-3 text-sm font-semibold text-white shadow-lg shadow-slate-900/15 transition hover:bg-slate-800">
                        Build schedule
                    </button>
                </div>
            </div>

            <div id="dailyScheduleState" class="mt-5 hidden rounded-xl border border-slate-200 bg-white p-4 text-sm text-slate-600 shadow-sm"></div>
            <div id="dailyScheduleResults" class="mt-5 hidden space-y-3"></div>
        </div>
    }

    <!-- Quick Insight Panels -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
        <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
            <div class="flex items-center justify-between mb-4">
                <h2 class="text-lg font-semibold text-gray-900">Recent tasks</h2>
                <span class="text-xs font-medium uppercase tracking-wide text-gray-400">Latest activity</span>
            </div>
            <div class="space-y-3">
                @if (Model.RecentTasks.Any())
                {
                    foreach (var task in Model.RecentTasks)
                    {
                        <div class="rounded-lg border border-gray-100 px-4 py-3">
                            <div class="flex items-center justify-between gap-4">
                                <p class="font-medium text-gray-900">@task.Title</p>
                                <span class="text-xs text-gray-500">@task.CreatedAt.ToLocalTime().ToString("MMM dd")</span>
                            </div>
                            @if (task.Score.HasValue)
                            {
                                <div class="mt-2 inline-flex rounded-full bg-blue-50 px-3 py-1 text-xs font-semibold text-blue-700">
                                    Score @task.Score.Value.ToString("0.00")
                                </div>
                            }
                            @if (!string.IsNullOrWhiteSpace(task.Description))
                            {
                                <p class="mt-1 text-sm text-gray-500 line-clamp-2">@task.Description</p>
                            }
                        </div>
                    }
                }
                else
                {
                    <p class="text-sm text-gray-500">No recent tasks yet.</p>
                }
            </div>
        </div>

        <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
            <div class="flex items-center justify-between mb-4">
                <h2 class="text-lg font-semibold text-gray-900">Upcoming tasks</h2>
                <span class="text-xs font-medium uppercase tracking-wide text-gray-400">Due soon</span>
            </div>
            <div class="space-y-3">
                @if (Model.UpcomingTasks.Any())
                {
                    foreach (var task in Model.UpcomingTasks)
                    {
                        <div class="flex items-center justify-between gap-4 rounded-lg border border-gray-100 px-4 py-3">
                            <div>
                                <p class="font-medium text-gray-900">@task.Title</p>
                                <p class="text-sm text-gray-500">@task.DueDate?.ToLocalTime().ToString("MMM dd, yyyy")</p>
                            </div>
                            <div class="flex flex-col items-end gap-2">
                                <span class="inline-flex rounded-full bg-blue-50 px-3 py-1 text-xs font-semibold text-blue-700">Priority @task.Priority</span>
                                @if (task.Score.HasValue)
                                {
                                    <span class="inline-flex rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-700">Score @task.Score.Value.ToString("0.00")</span>
                                }
                            </div>
                        </div>
                    }
                }
                else
                {
                    <p class="text-sm text-gray-500">Nothing is due soon.</p>
                }
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="flex justify-end mb-6">
        <button onclick="openModal()" class="flex items-center gap-2 bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 transition-colors font-medium">
            <i class="fas fa-plus"></i> Add New Task
        </button>
    </div>

    <!-- Tasks Table -->
    <div class="bg-white rounded-lg border border-gray-200 shadow-sm">
        <div class="p-6 border-b border-gray-200 flex justify-between items-center">
            <h3 class="text-lg font-semibold text-gray-800">My Tasks</h3>
            <div class="flex items-center gap-2">
                <input type="text" id="taskSearch" placeholder="Search tasks..."
                       class="px-3 py-1 border border-gray-300 rounded-lg text-sm">
                <select id="taskFilter" class="px-3 py-1 border border-gray-300 rounded-lg text-sm">
                    <option value="all">All Tasks</option>
                    <option value="pending">Pending</option>
                    <option value="inprogress">In Progress</option>
                    <option value="completed">Completed</option>
                </select>
            </div>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full">
                <thead>
                    <tr class="border-b border-gray-200 bg-gray-50">
                        <th class="px-6 py-4 text-left text-sm font-semibold text-gray-800">Task Name</th>
                        <th class="px-6 py-4 text-left text-sm font-semibold text-gray-800">Priority</th>
                        <th class="px-6 py-4 text-left text-sm font-semibold text-gray-800">Est. Time</th>
                        <th class="px-6 py-4 text-left text-sm font-semibold text-gray-800">Score</th>
                        <th class="px-6 py-4 text-left text-sm font-semibold text-gray-800">Due Date</th>
                        <th class="px-6 py-4 text-left text-sm font-semibold text-gray-800">Status</th>
                        <th class="px-6 py-4 text-left text-sm font-semibold text-gray-800">Actions</th>
                    </tr>
                </thead>
                <tbody id="taskTableBody">
                    <tr id="loadingRow">
                        <td colspan="7" class="px-6 py-8 text-center text-gray-500">
                            <i class="fas fa-spinner fa-spin text-2xl mb-2"></i>
                            <p>Loading tasks...</p>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="p-4 border-t border-gray-200 text-center">
            <button id="loadMoreBtn" onclick="loadMoreTasks()" class="text-blue-600 hover:text-blue-700 font-medium hidden">
                Load More Tasks
            </button>
        </div>
    </div>
</div>

<!-- Hidden fields for JavaScript -->
<input type="hidden" id="dashboardUserId" value="@Model.UserId" />
<input type="hidden" id="dashboardAuthToken" value="@Context.Session.GetString("Token")" />
<input type="hidden" id="userId" value="@Model.UserId" />
<input type="hidden" id="userName" value="@Model.UserName" />
<input type="hidden" id="userEmail" value="@Model.UserEmail" />
<input type="hidden" id="userRole" value="@Model.UserRole" />
<input type="hidden" id="authToken" value="@Context.Session.GetString("Token")" />

<!-- ===================== ADD TASK MODAL ===================== -->
<div id="addTaskModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 px-4">
    <div class="bg-white rounded-2xl shadow-xl w-full max-w-lg p-6 relative">

        <!-- Header -->
        <div class="flex items-center justify-between mb-5">
            <h3 class="text-lg font-semibold text-gray-900">Add new task</h3>
            <button onclick="closeModal()" class="text-gray-400 hover:text-gray-600 transition-colors">
                <i class="fas fa-times text-lg"></i>
            </button>
        </div>

        <!-- Voice Command Banner -->
        <div class="flex items-start gap-3 bg-purple-50 border border-purple-100 rounded-xl px-4 py-3 mb-5">
            <i class="fas fa-microphone text-purple-500 mt-0.5"></i>
            <div>
                <span class="text-sm font-semibold text-purple-700">Voice command</span>
                <span class="text-sm text-gray-500 ml-2">Click mic to use voice</span>
                <p class="text-xs text-gray-400 mt-0.5">Try: "Fix login bug priority high due tomorrow"</p>
            </div>
        </div>

        <!-- Task Name with Searchable Dropdown -->
        <div class="mb-4 relative">
            <label class="block text-sm font-medium text-gray-700 mb-1">
                Task name <span class="text-red-500">*</span>
            </label>
            <div class="relative">
                <input id="taskNameInput"
                       type="text"
                       placeholder="Search presets or type your own task..."
                       oninput="filterTaskPresets(this.value)"
                       onfocus="showTaskDropdown()"
                       autocomplete="off"
                       class="w-full border border-gray-300 rounded-lg px-3 py-2 pr-9 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
                <i class="fas fa-search absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 text-sm pointer-events-none"></i>
            </div>

            <!-- Dropdown -->
            <div id="taskPresetDropdown"
                 class="hidden absolute z-50 w-full bg-white border border-gray-200 rounded-xl shadow-lg mt-1 max-h-52 overflow-y-auto">
                <div id="presetList"></div>
            </div>
        </div>

        <!-- Description -->
        <div class="mb-4">
            <label class="block text-sm font-medium text-gray-700 mb-1">
                Description <span class="text-xs font-normal text-gray-400">(optional)</span>
            </label>
            <textarea id="taskDescInput"
                      rows="3"
                      placeholder="Add details, acceptance criteria, links..."
                      class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 resize-y"></textarea>
        </div>

        <div class="mb-4">
            <label class="block text-sm font-medium text-gray-700 mb-1">
                Estimated time <span class="text-xs font-normal text-gray-400">(minutes)</span>
            </label>
            <input id="taskEstimateInput"
                   type="number"
                   min="1"
                   step="15"
                   value="60"
                   class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
        </div>

        <!-- Priority + Status -->
        <div class="grid grid-cols-2 gap-3 mb-4">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Priority</label>
                <select id="taskPriorityInput" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
                    <option value="0">Low</option>
                    <option value="1" selected>Medium</option>
                    <option value="2">High</option>
                </select>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Status</label>
                <select id="taskStatusInput" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
                    <option value="2" selected>Pending</option>
                    
                </select>
            </div>
        </div>

        <!-- Due Date -->
        <div class="mb-5">
            <label class="block text-sm font-medium text-gray-700 mb-1">
                Due date <span class="text-red-500">*</span>
            </label>
            <input id="taskDueInput"
                   type="date"
                   class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
        </div>

        <!-- Actions -->
        <div class="flex justify-end gap-3">
            <button onclick="closeModal()"
                    class="px-4 py-2 text-sm font-medium text-gray-700 border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">
                Cancel
            </button>
            <button onclick="submitNewTask()"
                    class="flex items-center gap-2 px-4 py-2 text-sm font-medium text-white bg-blue-600 rounded-lg hover:bg-blue-700 transition-colors">
                <i class="fas fa-plus"></i> Add task
            </button>
        </div>
    </div>
</div>
<!-- ===================== END MODAL ===================== -->

@section Scripts {
    <script>
        const dashboardUserId = document.getElementById('dashboardUserId')?.value || userId;
        const dashboardAuthToken = document.getElementById('dashboardAuthToken')?.value || authToken;

        console.log('=== DASHBOARD INITIALIZED ===');
        console.log('UserId:', dashboardUserId);
        console.log('AuthToken exists:', !!dashboardAuthToken);
        console.log('API_BASE:', API_BASE);

        let allTasks = [];
        const itemsPerPage = 10;
        let currentPage = 1;

        function getDashboardAuthHeaders() {
            return {
                'Content-Type': 'application/json',
                'Authorization': `Bearer ${dashboardAuthToken}`
            };
        }

        document.addEventListener('DOMContentLoaded', async () => {
            if (!dashboardUserId || !dashboardAuthToken) {
                alert('Session expired. Redirecting to login...');
                window.location.href = '/Account/Login';
                return;
            }
            await loadTasks();
            setupEventListeners();
        });

        // ==================== MODAL ====================

        const TECH_PRESETS = [
            { label: 'Fix bug',                  icon: 'fa-bug',           tag: 'dev' },
            { label: 'Code review',              icon: 'fa-eye',           tag: 'dev' },
            { label: 'Write unit tests',         icon: 'fa-vial',          tag: 'qa' },
            { label: 'Write integration tests',  icon: 'fa-flask',         tag: 'qa' },
            { label: 'Deploy to staging',        icon: 'fa-rocket',        tag: 'devops' },
            { label: 'Deploy to production',     icon: 'fa-upload',        tag: 'devops' },
            { label: 'Update documentation',     icon: 'fa-file-alt',      tag: 'docs' },
            { label: 'Refactor code',            icon: 'fa-sync-alt',      tag: 'dev' },
            { label: 'Database migration',       icon: 'fa-database',      tag: 'backend' },
            { label: 'API endpoint review',      icon: 'fa-plug',          tag: 'backend' },
            { label: 'Performance optimization', icon: 'fa-tachometer-alt',tag: 'dev' },
            { label: 'Security audit',           icon: 'fa-shield-alt',    tag: 'security' },
            { label: 'Set up CI/CD pipeline',    icon: 'fa-code-branch',   tag: 'devops' },
            { label: 'Update dependencies',      icon: 'fa-box',           tag: 'devops' },
            { label: 'Design system update',     icon: 'fa-palette',       tag: 'frontend' },
            { label: 'Accessibility review',     icon: 'fa-universal-access', tag: 'frontend' },
            { label: 'Sprint planning',          icon: 'fa-calendar-alt',  tag: 'management' },
            { label: 'Retrospective meeting',    icon: 'fa-comments',      tag: 'management' },
        ];

        function openModal() {
            document.getElementById('addTaskModal').classList.remove('hidden');
            document.getElementById('addTaskModal').classList.add('flex');
            document.getElementById('taskNameInput').focus();
        }

        function closeModal() {
            document.getElementById('addTaskModal').classList.add('hidden');
            document.getElementById('addTaskModal').classList.remove('flex');
            document.getElementById('taskNameInput').value = '';
            document.getElementById('taskDescInput').value = '';
            document.getElementById('taskEstimateInput').value = '60';
            document.getElementById('taskDueInput').value = '';
            document.getElementById('taskPriorityInput').value = '1';
            document.getElementById('taskStatusInput').value = '2';
            document.getElementById('taskPresetDropdown').classList.add('hidden');
        }

        function showTaskDropdown() {
            filterTaskPresets(document.getElementById('taskNameInput').value);
        }

        function filterTaskPresets(val) {
            const q = val.trim().toLowerCase();
            const list = document.getElementById('presetList');
            const dropdown = document.getElementById('taskPresetDropdown');

            const filtered = q
                ? TECH_PRESETS.filter(t => t.label.toLowerCase().includes(q))
                : TECH_PRESETS;

            let html = filtered.map(t => `
                <div onclick="selectPreset('${t.label}')"
                     class="flex items-center gap-3 px-4 py-2.5 cursor-pointer hover:bg-gray-50 border-b border-gray-100 last:border-0">
                    <i class="fas ${t.icon} text-gray-400 w-4 text-center"></i>
                    <span class="text-sm text-gray-800 flex-1">${t.label}</span>
                    <span class="text-xs px-2 py-0.5 rounded-full bg-gray-100 text-gray-500">${t.tag}</span>
                </div>
            `).join('');

            if (q && filtered.length === 0) {
                html = `
                    <div class="flex items-center gap-3 px-4 py-3 text-sm text-gray-500">
                        <i class="fas fa-info-circle text-gray-400"></i>
                        No preset found — just click <strong class="mx-1 text-gray-700">Add task</strong> to save your custom task
                    </div>`;
            }

            list.innerHTML = html;
            dropdown.classList.remove('hidden');
        }

        function selectPreset(name) {
            document.getElementById('taskNameInput').value = name;
            document.getElementById('taskPresetDropdown').classList.add('hidden');
        }

        document.addEventListener('click', function (e) {
            if (!e.target.closest('#taskNameInput') && !e.target.closest('#taskPresetDropdown')) {
                document.getElementById('taskPresetDropdown').classList.add('hidden');
            }
        });

        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') closeModal();
        });

        async function submitNewTask() {
            const title = document.getElementById('taskNameInput').value.trim();
            const description = document.getElementById('taskDescInput').value.trim();
            const estimatedMinutes = parseInt(document.getElementById('taskEstimateInput').value);
            const priority = parseInt(document.getElementById('taskPriorityInput').value);
            const status = parseInt(document.getElementById('taskStatusInput').value);
            const dueDate = document.getElementById('taskDueInput').value;

            if (!title) {
                document.getElementById('taskNameInput').focus();
                showError('Task name is required.');
                return;
            }
            if (!dueDate) {
                document.getElementById('taskDueInput').focus();
                showError('Due date is required.');
                return;
            }

            try {
                const response = await fetch(`${API_BASE}/tasks`, {
                    method: 'POST',
                    headers: getDashboardAuthHeaders(),
                    body: JSON.stringify({
                        title,
                        description,
                        estimatedMinutes,
                        priority,
                        status,
                        dueDate: new Date(dueDate).toISOString(),
                        userId: dashboardUserId
                    })
                });

                const result = await response.json();

                if (result.success) {
                    showSuccess('Task added successfully!');
                    closeModal();
                    await loadTasks();
                } else {
                    showError(result.message || 'Failed to add task.');
                }
            } catch (error) {
                console.error('Error adding task:', error);
                showError('Error adding task: ' + error.message);
            }
        }

        // ==================== TASKS ====================

        async function loadTasks() {
            const tableBody = document.getElementById('taskTableBody');
            const loadingRow = document.getElementById('loadingRow');

            try {
                const url = `${API_BASE}/tasks/user/${dashboardUserId}`;
                const response = await fetch(url, { method: 'GET', headers: getDashboardAuthHeaders() });

                if (!response.ok) throw new Error(`HTTP error ${response.status}`);

                const result = await response.json();
                let tasks = [];

                if (result.success && result.data)       tasks = result.data;
                else if (result.success && result.tasks) tasks = result.tasks;
                else if (Array.isArray(result))          tasks = result;
                else if (result.success)                 tasks = [];

                allTasks = tasks;
                displayTasks(allTasks);
                updateStatistics(allTasks);
                if (document.getElementById('dailyScheduleResults') && !document.getElementById('dailyScheduleResults').classList.contains('hidden')) {
                    await generateDailySchedule();
                }

            } catch (error) {
                console.error('Error loading tasks:', error);
                showError('Failed to load tasks: ' + error.message);
                if (loadingRow) loadingRow.remove();
                tableBody.innerHTML = `
                    <tr>
                        <td colspan="7" class="px-6 py-12 text-center text-red-500">
                            <i class="fas fa-exclamation-triangle text-4xl mb-4"></i>
                            <p class="text-lg font-medium mb-2">Failed to load tasks</p>
                            <p class="text-sm text-gray-600">${error.message}</p>
                            <button onclick="loadTasks()" class="mt-4 bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700">
                                <i class="fas fa-redo mr-2"></i>Retry
                            </button>
                        </td>
                    </tr>`;
            }
        }

        function displayTasks(tasks) {
            const tableBody = document.getElementById('taskTableBody');
            const loadingRow = document.getElementById('loadingRow');
            if (loadingRow) loadingRow.remove();

            if (!tasks || tasks.length === 0) {
                tableBody.innerHTML = `
                    <tr>
                        <td colspan="6" class="px-6 py-12 text-center text-gray-500">
                            <i class="fas fa-inbox text-4xl mb-4 text-gray-300"></i>
                            <p class="text-lg font-medium text-gray-600 mb-2">No tasks yet</p>
                            <p class="text-sm text-gray-500 mb-4">Create your first task to get started</p>
                            <button onclick="openModal()" class="bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700">
                                <i class="fas fa-plus mr-2"></i>Create Your First Task
                            </button>
                        </td>
                    </tr>`;
                return;
            }

            tableBody.innerHTML = tasks.map(task => `
                <tr class="border-b hover:bg-gray-50 transition-colors">
                    <td class="px-6 py-4">
                        <div class="text-sm font-medium text-gray-900">${task.title || 'Untitled Task'}</div>
                        ${task.description ? `<div class="text-xs text-gray-500 mt-1">${task.description}</div>` : ''}
                    </td>
                    <td class="px-6 py-4 text-sm">
                        <span class="px-2 py-1 rounded-full text-xs font-medium ${getPriorityClass(task.priority)}">
                            ${getPriorityText(task.priority)}
                        </span>
                    </td>
                    <td class="px-6 py-4 text-sm text-gray-600">
                        ${task.estimatedMinutes ? `${task.estimatedMinutes} min` : '60 min'}
                    </td>
                    <td class="px-6 py-4 text-sm">
                        ${renderScoreBadge(task.score)}
                    </td>
                    <td class="px-6 py-4 text-sm text-gray-600">
                        ${task.dueDate ? new Date(task.dueDate).toLocaleDateString() : 'No due date'}
                    </td>
                    <td class="px-6 py-4 text-sm">
                        <select onchange="updateTaskStatus(${task.id}, this.value)"
                                class="px-2 py-1 rounded-full text-xs font-medium border-0 cursor-pointer ${getStatusClass(task.status)}">
                            <option value="0" ${task.status === 0 ? 'selected' : ''}>Completed</option>
                            <option value="1" ${task.status === 1 ? 'selected' : ''}>In Progress</option>
                            <option value="2" ${task.status === 2 ? 'selected' : ''}>Pending</option>
                        </select>
                    </td>
                    <td class="px-6 py-4 text-sm">
                        <div class="flex gap-2">
                            <button onclick="editTask(${task.id})"
                                    class="p-2 hover:bg-blue-50 rounded-lg text-blue-600 transition-colors" title="Edit">
                                <i class="fas fa-edit"></i>
                            </button>
                            <button onclick="deleteTask(${task.id})"
                                    class="p-2 hover:bg-red-50 rounded-lg text-red-600 transition-colors" title="Delete">
                                <i class="fas fa-trash"></i>
                            </button>
                        </div>
                    </td>
                </tr>
            `).join('');
        }

        function updateStatistics(tasks) {
            const today = new Date().toISOString().split('T')[0];
            document.getElementById('totalTasks').textContent     = tasks.length;
            document.getElementById('completedTasks').textContent = tasks.filter(t => t.status === 0).length;
            document.getElementById('pendingTasks').textContent   = tasks.filter(t => t.status === 2).length;
            document.getElementById('overdueTasks').textContent   = tasks.filter(t =>
                t.dueDate && t.dueDate < today && t.status !== 0).length;
        }

        function getPriorityText(priority) {
            return ['Low', 'Medium', 'High'][priority] ?? 'Medium';
        }

        function getPriorityClass(priority) {
            return ['bg-green-100 text-green-800', 'bg-yellow-100 text-yellow-800', 'bg-red-100 text-red-800'][priority] ?? 'bg-gray-100 text-gray-800';
        }

        function getStatusClass(status) {
            return ['bg-green-100 text-green-800', 'bg-blue-100 text-blue-800', 'bg-gray-100 text-gray-800'][status] ?? 'bg-gray-100 text-gray-800';
        }

        function renderScoreBadge(score) {
            const value = Number(score);

            if (Number.isNaN(value)) {
                return '<span class="inline-flex rounded-full bg-gray-100 px-2 py-1 text-xs font-medium text-gray-500">n/a</span>';
            }

            const tone = value >= 0.75
                ? 'bg-emerald-100 text-emerald-800'
                : value >= 0.5
                    ? 'bg-blue-100 text-blue-800'
                    : 'bg-amber-100 text-amber-800';

            return `<span class="inline-flex rounded-full px-2 py-1 text-xs font-medium ${tone}">${value.toFixed(2)}</span>`;
        }

        async function generateDailySchedule() {
            const scheduleState = document.getElementById('dailyScheduleState');
            const scheduleResults = document.getElementById('dailyScheduleResults');

            if (!scheduleState || !scheduleResults) {
                return;
            }

            const availableMinutes = parseInt(document.getElementById('dailyAvailableMinutes')?.value || '0');

            if (!availableMinutes || availableMinutes <= 0) {
                scheduleState.classList.remove('hidden');
                scheduleResults.classList.add('hidden');
                scheduleState.innerHTML = '<span class="font-semibold text-amber-700">Enter a valid number of minutes to build today\'s schedule.</span>';
                return;
            }

            scheduleState.classList.remove('hidden');
            scheduleResults.classList.add('hidden');
            scheduleState.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i> Building today\'s schedule...';

            try {
                const response = await fetch(`${API_BASE}/tasks/daily-schedule`, {
                    method: 'POST',
                    headers: getDashboardAuthHeaders(),
                    body: JSON.stringify({
                        userId: dashboardUserId,
                        availableMinutes
                    })
                });

                const result = await response.json();

                if (!result.success || !result.data) {
                    throw new Error(result.message || 'Failed to generate schedule');
                }

                const schedule = result.data;
                scheduleState.innerHTML = `
                    <div class="flex flex-col gap-1 sm:flex-row sm:items-center sm:justify-between">
                        <span class="font-semibold text-slate-900">Schedule ready</span>
                        <span class="text-slate-600">${schedule.scheduledMinutes} of ${schedule.availableMinutes} minutes allocated</span>
                    </div>
                `;

                const scheduledHtml = schedule.scheduledTasks.length > 0
                    ? schedule.scheduledTasks.map(item => `
                        <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
                            <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
                                <div>
                                    <div class="flex items-center gap-2">
                                        <span class="inline-flex h-7 w-7 items-center justify-center rounded-full bg-slate-900 text-xs font-semibold text-white">${item.plannedOrder}</span>
                                        <h4 class="font-semibold text-slate-900">${item.title}</h4>
                                    </div>
                                    ${item.description ? `<p class="mt-2 text-sm text-slate-600">${item.description}</p>` : ''}
                                </div>
                                <div class="flex flex-wrap gap-2 text-xs font-semibold">
                                    <span class="rounded-full bg-indigo-50 px-3 py-1 text-indigo-700">${item.estimatedMinutes} min</span>
                                    <span class="rounded-full bg-blue-50 px-3 py-1 text-blue-700">Score ${Number(item.score).toFixed(2)}</span>
                                    <span class="rounded-full bg-slate-100 px-3 py-1 text-slate-700">Priority ${getPriorityText(item.priority)}</span>
                                </div>
                            </div>
                        </div>
                    `).join('')
                    : '<div class="rounded-xl border border-dashed border-slate-300 bg-white p-4 text-sm text-slate-500">No tasks fit within the current time budget.</div>';

                const unscheduledHtml = schedule.unscheduledTasks.length > 0
                    ? `
                        <div class="rounded-xl border border-amber-200 bg-amber-50 p-4 text-sm text-amber-900">
                            <p class="font-semibold">Tasks left for another day</p>
                            <p class="mt-1 text-amber-800">${schedule.unscheduledTasks.length} task(s) were not selected because they do not fit inside today's time budget.</p>
                        </div>
                    `
                    : '';

                scheduleResults.innerHTML = `
                    <div class="space-y-3">
                        ${scheduledHtml}
                        ${unscheduledHtml}
                    </div>
                `;
                scheduleResults.classList.remove('hidden');
            } catch (error) {
                scheduleState.innerHTML = `<span class="font-semibold text-red-700">${error.message}</span>`;
                scheduleResults.classList.add('hidden');
            }
        }

        async function updateTaskStatus(taskId, newStatus) {
            try {
                const response = await fetch(`${API_BASE}/tasks/${taskId}/status`, {
                    method: 'PATCH',
                    headers: getDashboardAuthHeaders(),
                    body: JSON.stringify({ status: parseInt(newStatus) })
                });
                const result = await response.json();
                if (result.success) { showSuccess('Task status updated!'); await loadTasks(); }
                else showError(result.message || 'Failed to update status');
            } catch (error) { showError('Error updating task status'); }
        }

        async function deleteTask(taskId) {
            if (!confirm('Are you sure you want to delete this task?')) return;
            try {
                const response = await fetch(`${API_BASE}/tasks/${taskId}`, {
                    method: 'DELETE',
                    headers: getDashboardAuthHeaders()
                });
                const result = await response.json();
                if (result.success) { showSuccess('Task deleted successfully!'); await loadTasks(); }
                else showError(result.message || 'Failed to delete task');
            } catch (error) { showError('Error deleting task'); }
        }

        function editTask(taskId) {
            window.location.href = `/Tasks/Edit?id=${taskId}`;
        }

        function setupEventListeners() {
            document.getElementById('taskSearch')?.addEventListener('input', function (e) {
                const q = e.target.value.toLowerCase();
                displayTasks(allTasks.filter(t =>
                    t.title.toLowerCase().includes(q) ||
                    (t.description && t.description.toLowerCase().includes(q))
                ));
            });

            document.getElementById('taskFilter')?.addEventListener('change', function (e) {
                const status = e.target.value;
                if (status === 'all') { displayTasks(allTasks); return; }
                const statusMap = { pending: 2, inprogress: 1, completed: 0 };
                displayTasks(allTasks.filter(t => t.status === statusMap[status]));
            });
        }

        function showSuccess(message) {
            const toast = document.createElement('div');
            toast.className = 'fixed top-20 right-4 bg-green-500 text-white px-6 py-3 rounded-lg shadow-lg z-50 flex items-center gap-2';
            toast.innerHTML = `<i class="fas fa-check-circle"></i><span>${message}</span>`;
            document.body.appendChild(toast);
            setTimeout(() => { toast.style.opacity = '0'; toast.style.transition = 'opacity 0.3s'; setTimeout(() => toast.remove(), 300); }, 3000);
        }

        function showError(message) {
            const toast = document.createElement('div');
            toast.className = 'fixed top-20 right-4 bg-red-500 text-white px-6 py-3 rounded-lg shadow-lg z-50 flex items-center gap-2';
            toast.innerHTML = `<i class="fas fa-exclamation-circle"></i><span>${message}</span>`;
            document.body.appendChild(toast);
            setTimeout(() => { toast.style.opacity = '0'; toast.style.transition = 'opacity 0.3s'; setTimeout(() => toast.remove(), 300); }, 5000);
        }
    </script>
}
