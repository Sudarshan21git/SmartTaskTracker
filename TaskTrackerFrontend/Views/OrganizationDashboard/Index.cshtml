@{
    ViewData["Title"] = "Organization Dashboard";
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";
}

<div class="max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
        <div class="lg:col-span-2 rounded-2xl bg-gradient-to-r from-indigo-950 via-slate-900 to-slate-800 text-white p-8 shadow-xl">
            <div class="inline-flex items-center gap-2 rounded-full bg-white/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] text-slate-200 mb-4">
                <span>Organization</span>
                <span class="h-1 w-1 rounded-full bg-cyan-400"></span>
                <span>Team management</span>
            </div>
            <h1 class="text-3xl font-bold mb-3">Welcome, <span class="text-cyan-300">@ViewBag.OrgName</span> 👋</h1>
            <p class="text-slate-300 max-w-2xl">Manage your team roster, track activation status, and review new employee credentials from one place.</p>
        </div>

        <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <h2 class="text-lg font-semibold text-slate-900 mb-4">Organization profile</h2>
            <div class="space-y-3 text-sm">
                <div class="flex items-center justify-between gap-4">
                    <span class="text-slate-500">Organization</span>
                    <span class="font-medium text-slate-900 text-right">@ViewBag.OrgName</span>
                </div>
                <div class="flex items-center justify-between gap-4">
                    <span class="text-slate-500">Email</span>
                    <span class="font-medium text-slate-900 text-right break-all">@ViewBag.OrgEmail</span>
                </div>
                <div class="flex items-center justify-between gap-4">
                    <span class="text-slate-500">Organization ID</span>
                    <span class="inline-flex rounded-full bg-blue-50 px-3 py-1 text-xs font-semibold text-blue-700">#@ViewBag.OrgId</span>
                </div>
            </div>
        </div>
    </div>

    @if (ViewBag.ShowCredentials == true)
    {
        <div class="mb-8 rounded-2xl border border-emerald-200 bg-emerald-50 p-6 shadow-sm">
            <h2 class="text-lg font-semibold text-emerald-900 mb-4">New employee credentials sent</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-4 text-sm text-emerald-900">
                <div>
                    <p class="text-emerald-700">Name</p>
                    <p class="font-semibold">@ViewBag.NewEmployeeName</p>
                </div>
                <div>
                    <p class="text-emerald-700">Email</p>
                    <p class="font-semibold break-all">@ViewBag.NewEmployeeEmail</p>
                </div>
                <div>
                    <p class="text-emerald-700">Employee code</p>
                    <p class="font-semibold">@ViewBag.NewEmployeeCode</p>
                </div>
                <div>
                    <p class="text-emerald-700">Temporary password</p>
                    <p class="font-semibold">@ViewBag.NewEmployeePassword</p>
                </div>
            </div>
        </div>
    }

    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6 mb-8">
        <div class="rounded-xl border border-blue-100 bg-blue-50 p-6 shadow-sm">
            <p class="text-sm font-medium text-blue-600">Total employees</p>
            <h3 class="mt-2 text-3xl font-bold text-blue-700" id="totalEmployees">--</h3>
        </div>
        <div class="rounded-xl border border-emerald-100 bg-emerald-50 p-6 shadow-sm">
            <p class="text-sm font-medium text-emerald-600">Active employees</p>
            <h3 class="mt-2 text-3xl font-bold text-emerald-700" id="activeEmployees">--</h3>
        </div>
        <div class="rounded-xl border border-amber-100 bg-amber-50 p-6 shadow-sm">
            <p class="text-sm font-medium text-amber-600">Recent hires</p>
            <h3 class="mt-2 text-3xl font-bold text-amber-700" id="recentHires">--</h3>
        </div>
        <div class="rounded-xl border border-rose-100 bg-rose-50 p-6 shadow-sm">
            <p class="text-sm font-medium text-rose-600">Inactive employees</p>
            <h3 class="mt-2 text-3xl font-bold text-rose-700" id="inactiveEmployees">--</h3>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
        <a href="@Url.Action("Create", "OrgEmployees")" class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm transition hover:shadow-md">
            <h2 class="mb-2 text-lg font-bold text-gray-800">👤 Add Employee</h2>
            <p class="text-sm text-gray-500">Create employee account and send login email.</p>
        </a>
        <a href="@Url.Action("Create", "Projects")" class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm transition hover:shadow-md">
            <h2 class="mb-2 text-lg font-bold text-gray-800">📁 Add Project</h2>
            <p class="text-sm text-gray-500">Create new project for your organization.</p>
        </a>
        <a href="@Url.Action("Create", "OrganizationTasks")" class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm transition hover:shadow-md">
            <h2 class="mb-2 text-lg font-bold text-gray-800">📋 Assign Task</h2>
            <p class="text-sm text-gray-500">Assign task to developer or employee.</p>
        </a>
        <a href="@Url.Action("Index", "OrgEmployees")" class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm transition hover:shadow-md">
            <h2 class="mb-2 text-lg font-bold text-gray-800">💻 Developers</h2>
            <p class="text-sm text-gray-500">View all developers and workload.</p>
        </a>
    </div>

    <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm mb-8">
        <div class="flex flex-col gap-2 lg:flex-row lg:items-center lg:justify-between mb-4">
            <div>
                <h2 class="text-lg font-semibold text-gray-900">Team roster</h2>
                <p class="text-sm text-gray-500">Employees created under this organization, ordered by newest first.</p>
            </div>
            <button onclick="loadOrganizationEmployees()" class="inline-flex items-center justify-center rounded-lg bg-slate-900 px-4 py-2 text-sm font-medium text-white transition hover:bg-slate-700">Refresh roster</button>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead>
                    <tr class="border-b border-gray-200 text-left text-gray-600">
                        <th class="pb-3 font-medium">Name</th>
                        <th class="pb-3 font-medium">Department</th>
                        <th class="pb-3 font-medium">Position</th>
                        <th class="pb-3 font-medium">Code</th>
                        <th class="pb-3 font-medium">Status</th>
                    </tr>
                </thead>
                <tbody id="employeeTableBody">
                    <tr>
                        <td colspan="5" class="py-8 text-center text-gray-400">Loading employees...</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<input type="hidden" id="organizationId" value="@ViewBag.OrgId" />
<input type="hidden" id="organizationAuthToken" value="@Context.Session.GetString("Token")" />

@section Scripts {
    <script>
        const organizationAuthToken = document.getElementById('organizationAuthToken')?.value || (typeof authToken !== 'undefined' ? authToken : '');

        let organizationEmployees = [];

        function getOrganizationHeaders() {
            return {
                'Content-Type': 'application/json',
                'Authorization': `Bearer ${organizationAuthToken}`
            };
        }

        document.addEventListener('DOMContentLoaded', async () => {
            if (!organizationAuthToken) {
                alert('Session expired. Redirecting to login...');
                window.location.href = '/Account/Login';
                return;
            }

            await loadOrganizationEmployees();
        });

        async function loadOrganizationEmployees() {
            const tableBody = document.getElementById('employeeTableBody');

            try {
                const response = await fetch(`${API_BASE}/organization/employees`, {
                    method: 'GET',
                    headers: getOrganizationHeaders()
                });

                if (!response.ok) {
                    const errorText = await response.text();
                    throw new Error(errorText || `HTTP error ${response.status}`);
                }

                const employees = await response.json();
                organizationEmployees = Array.isArray(employees) ? employees : [];

                updateOrganizationStatistics(organizationEmployees);
                displayOrganizationEmployees(organizationEmployees);
            }
            catch (error) {
                console.error('Error loading organization employees:', error);
                tableBody.innerHTML = `
                    <tr>
                        <td colspan="5" class="py-10 text-center text-red-500">
                            <p class="font-medium mb-1">Failed to load employees</p>
                            <p class="text-sm text-gray-600">${error.message}</p>
                            <button onclick="loadOrganizationEmployees()" class="mt-4 rounded-lg bg-slate-900 px-4 py-2 text-white hover:bg-slate-700">Retry</button>
                        </td>
                    </tr>`;
                showError('Failed to load employees');
            }
        }

        function updateOrganizationStatistics(employees) {
            const totalEmployees = employees.length;
            const activeEmployees = employees.filter(employee => employee.isActive ?? employee.IsActive).length;
            const recentHires = employees.filter(employee => {
                const createdAt = new Date(employee.createdAt ?? employee.CreatedAt);
                const ageInDays = (Date.now() - createdAt.getTime()) / (1000 * 60 * 60 * 24);
                return ageInDays <= 7;
            }).length;

            document.getElementById('totalEmployees').textContent = totalEmployees;
            document.getElementById('activeEmployees').textContent = activeEmployees;
            document.getElementById('recentHires').textContent = recentHires;
            document.getElementById('inactiveEmployees').textContent = Math.max(totalEmployees - activeEmployees, 0);
        }

        function displayOrganizationEmployees(employees) {
            const tableBody = document.getElementById('employeeTableBody');

            if (!employees || employees.length === 0) {
                tableBody.innerHTML = `
                    <tr>
                        <td colspan="5" class="py-10 text-center text-gray-500">
                            <p class="font-medium text-gray-600 mb-1">No employees yet</p>
                            <p class="text-sm text-gray-500">Use Add Employee to build your team roster.</p>
                        </td>
                    </tr>`;
                return;
            }

            tableBody.innerHTML = employees.map(employee => {
                const isActive = employee.isActive ?? employee.IsActive;
                return `
                    <tr class="border-b border-gray-100 hover:bg-gray-50 transition-colors">
                        <td class="px-0 py-4">
                            <div class="font-medium text-gray-900">${employee.fullName ?? employee.FullName ?? 'Unknown'}</div>
                            <div class="text-xs text-gray-500">${employee.email ?? employee.Email ?? ''}</div>
                        </td>
                        <td class="px-0 py-4 text-gray-600">${employee.department ?? employee.Department ?? 'Unassigned'}</td>
                        <td class="px-0 py-4 text-gray-600">${employee.position ?? employee.Position ?? 'N/A'}</td>
                        <td class="px-0 py-4 text-gray-600">${employee.employeeCode ?? employee.EmployeeCode ?? 'N/A'}</td>
                        <td class="px-0 py-4">
                            <span class="inline-flex rounded-full px-3 py-1 text-xs font-semibold ${isActive ? 'bg-emerald-100 text-emerald-700' : 'bg-rose-100 text-rose-700'}">
                                ${isActive ? 'Active' : 'Inactive'}
                            </span>
                        </td>
                    </tr>`;
            }).join('');
        }

        function showError(message) {
            const toast = document.createElement('div');
            toast.className = 'fixed top-20 right-4 z-50 rounded-lg bg-red-500 px-6 py-3 text-white shadow-lg';
            toast.textContent = message;
            document.body.appendChild(toast);
            setTimeout(() => toast.remove(), 5000);
        }
    </script>
}