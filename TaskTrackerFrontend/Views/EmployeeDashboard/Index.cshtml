@{
    ViewData["Title"] = "Employee Dashboard";
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";
}

<div class="max-w-7xl mx-auto">
    @if (ViewBag.MustChangePassword == true)
    {
        <div class="mb-6 rounded-2xl border border-amber-200 bg-amber-50 px-5 py-4 text-amber-900">
            <div class="flex items-start gap-3">
                <div class="mt-0.5 h-3 w-3 rounded-full bg-amber-500"></div>
                <div>
                    <p class="font-semibold">Temporary password active</p>
                    <p class="text-sm text-amber-800">Change your password now to continue using your account securely.</p>
                </div>
            </div>
        </div>
    }

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
        <div class="lg:col-span-2 rounded-2xl bg-slate-900 text-white p-8 shadow-xl">
            <div class="inline-flex items-center gap-2 rounded-full bg-white/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] text-slate-200 mb-4">
                <span>Employee</span>
                <span class="h-1 w-1 rounded-full bg-cyan-400"></span>
                <span>Assigned work</span>
            </div>
            <h1 class="text-3xl font-bold mb-3">Welcome, <span class="text-cyan-300">@ViewBag.EmployeeName</span> 👋</h1>
            <p class="text-slate-300 max-w-2xl">
                Track your assigned work, update progress as you move, and keep your department context visible.
            </p>
        </div>

        <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <h2 class="text-lg font-semibold text-slate-900 mb-4">Account details</h2>
            <div class="space-y-3 text-sm">
                <div class="flex items-center justify-between gap-4">
                    <span class="text-slate-500">Department</span>
                    <span class="font-medium text-slate-900 text-right">@(string.IsNullOrWhiteSpace(ViewBag.Department as string) ? "Unassigned" : ViewBag.Department)</span>
                </div>
                <div class="flex items-center justify-between gap-4">
                    <span class="text-slate-500">Email</span>
                    <span class="font-medium text-slate-900 text-right">@(string.IsNullOrWhiteSpace(ViewBag.EmployeeEmail as string) ? "N/A" : ViewBag.EmployeeEmail)</span>
                </div>
                <div class="flex items-center justify-between gap-4">
                    <span class="text-slate-500">Employee code</span>
                    <span class="font-medium text-slate-900 text-right">@(string.IsNullOrWhiteSpace(ViewBag.EmployeeCode as string) ? "N/A" : ViewBag.EmployeeCode)</span>
                </div>
                <div class="flex items-center justify-between gap-4">
                    <span class="text-slate-500">Access</span>
                    <span class="inline-flex rounded-full bg-blue-50 px-3 py-1 text-xs font-semibold text-blue-700">Employee role</span>
                </div>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6 mb-8">
        <div class="rounded-xl border border-blue-100 bg-blue-50 p-6 shadow-sm">
            <p class="text-sm font-medium text-blue-600">My tasks</p>
            <h3 class="mt-2 text-3xl font-bold text-blue-700" id="totalTasks">--</h3>
        </div>
        <div class="rounded-xl border border-amber-100 bg-amber-50 p-6 shadow-sm">
            <p class="text-sm font-medium text-amber-600">In progress</p>
            <h3 class="mt-2 text-3xl font-bold text-amber-700" id="inProgressTasks">--</h3>
        </div>
        <div class="rounded-xl border border-emerald-100 bg-emerald-50 p-6 shadow-sm">
            <p class="text-sm font-medium text-emerald-600">Completed</p>
            <h3 class="mt-2 text-3xl font-bold text-emerald-700" id="completedTasks">--</h3>
        </div>
        <div class="rounded-xl border border-rose-100 bg-rose-50 p-6 shadow-sm">
            <p class="text-sm font-medium text-rose-600">Overdue</p>
            <h3 class="mt-2 text-3xl font-bold text-rose-700" id="overdueTasks">--</h3>
        </div>
    </div>

    <div class="rounded-2xl border border-gray-200 bg-white shadow-sm">
        <div class="flex flex-col gap-4 border-b border-gray-200 p-6 lg:flex-row lg:items-center lg:justify-between">
            <div>
                <h2 class="text-lg font-semibold text-gray-900">Assigned tasks</h2>
                <p class="text-sm text-gray-500">Update task status as work progresses.</p>
            </div>
            <div class="flex flex-wrap items-center gap-2">
                <input type="text" id="taskSearch" placeholder="Search tasks..." class="rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-blue-500 focus:outline-none">
                <select id="taskFilter" class="rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-blue-500 focus:outline-none">
                    <option value="all">All tasks</option>
                    <option value="pending">Pending</option>
                    <option value="inprogress">In Progress</option>
                    <option value="completed">Completed</option>
                </select>
            </div>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead>
                    <tr class="border-b border-gray-200 bg-gray-50 text-left text-gray-600">
                        <th class="px-6 py-4 font-semibold">Task</th>
                        <th class="px-6 py-4 font-semibold">Priority</th>
                        <th class="px-6 py-4 font-semibold">Due date</th>
                        <th class="px-6 py-4 font-semibold">Status</th>
                        <th class="px-6 py-4 font-semibold">Action</th>
                    </tr>
                </thead>
                <tbody id="taskTableBody">
                    <tr id="loadingRow">
                        <td colspan="5" class="px-6 py-10 text-center text-gray-500">
                            Loading tasks...
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Force Change Password Modal -->
    @if (ViewBag.MustChangePassword == true)
    {
        <div id="changePasswordModal" class="fixed inset-0 z-50 flex items-center justify-center bg-black bg-opacity-60">
            <div class="mx-4 w-full max-w-md rounded-2xl bg-white p-8 shadow-2xl">
                <div class="mb-6 text-center">
                    <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-yellow-100">
                        <svg class="h-8 w-8 text-yellow-600" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                        </svg>
                    </div>
                    <h2 class="text-2xl font-bold text-gray-900">Change Your Password</h2>
                    <p class="mt-2 text-sm text-gray-500">You are using a temporary password. Please set a new password to continue.</p>
                </div>

                <div class="space-y-4">
                    <div>
                        <label class="mb-1 block text-sm font-medium text-gray-700">Temporary Password</label>
                        <input type="password" id="tempPassword" placeholder="Enter temporary password" class="w-full rounded-lg border border-gray-300 px-4 py-3 focus:outline-none focus:ring-2 focus:ring-blue-500">
                    </div>
                    <div>
                        <label class="mb-1 block text-sm font-medium text-gray-700">New Password</label>
                        <input type="password" id="newPassword" placeholder="Min 6 chars, 1 capital, 1 number" class="w-full rounded-lg border border-gray-300 px-4 py-3 focus:outline-none focus:ring-2 focus:ring-blue-500">
                    </div>
                    <div>
                        <label class="mb-1 block text-sm font-medium text-gray-700">Confirm New Password</label>
                        <input type="password" id="confirmPassword" placeholder="Repeat new password" class="w-full rounded-lg border border-gray-300 px-4 py-3 focus:outline-none focus:ring-2 focus:ring-blue-500">
                    </div>

                    <div id="pwError" class="hidden rounded-lg bg-red-50 p-3 text-sm text-red-700"></div>

                    <button onclick="submitNewPassword()" class="w-full rounded-lg bg-blue-600 py-3 font-semibold text-white transition hover:bg-blue-700">
                        Set New Password
                    </button>
                </div>
            </div>
        </div>
    }
</div>

<input type="hidden" id="employeeUserId" value="@Context.Session.GetInt32("UserId")" />
<input type="hidden" id="employeeAuthToken" value="@Context.Session.GetString("Token")" />

@section Scripts {
    <script>
        const employeeUserId = document.getElementById('employeeUserId')?.value || (typeof userId !== 'undefined' ? userId : '');
        const employeeAuthToken = document.getElementById('employeeAuthToken')?.value || (typeof authToken !== 'undefined' ? authToken : '');

        let employeeTasks = [];

        function getEmployeeHeaders() {
            return {
                'Content-Type': 'application/json',
                'Authorization': `Bearer ${employeeAuthToken}`
            };
        }

        document.addEventListener('DOMContentLoaded', async () => {
            if (!employeeUserId || !employeeAuthToken) {
                alert('Session expired. Redirecting to login...');
                window.location.href = '/Account/Login';
                return;
            }

            await loadEmployeeTasks();
            setupEventListeners();
        });

        async function loadEmployeeTasks() {
            const tableBody = document.getElementById('taskTableBody');
            const loadingRow = document.getElementById('loadingRow');

            try {
                const response = await fetch(`${API_BASE}/tasks/user/${employeeUserId}`, {
                    method: 'GET',
                    headers: getEmployeeHeaders()
                });

                if (!response.ok) {
                    const errorText = await response.text();
                    throw new Error(errorText || `HTTP error ${response.status}`);
                }

                const result = await response.json();
                let tasks = [];

                if (result.success && result.data) {
                    tasks = result.data;
                } else if (result.success && result.tasks) {
                    tasks = result.tasks;
                } else if (Array.isArray(result)) {
                    tasks = result;
                }

                employeeTasks = tasks;
                displayTasks(employeeTasks);
                updateStatistics(employeeTasks);
            }
            catch (error) {
                console.error('Error loading employee tasks:', error);
                if (loadingRow) {
                    loadingRow.remove();
                }

                tableBody.innerHTML = `
                    <tr>
                        <td colspan="5" class="px-6 py-12 text-center text-red-500">
                            <p class="text-lg font-medium mb-2">Failed to load tasks</p>
                            <p class="text-sm text-gray-600">${error.message}</p>
                            <button onclick="loadEmployeeTasks()" class="mt-4 rounded-lg bg-blue-600 px-4 py-2 text-white hover:bg-blue-700">Retry</button>
                        </td>
                    </tr>`;
                showError('Failed to load tasks');
            }
        }

        function displayTasks(tasks) {
            const tableBody = document.getElementById('taskTableBody');
            const loadingRow = document.getElementById('loadingRow');

            if (loadingRow) {
                loadingRow.remove();
            }

            if (!tasks || tasks.length === 0) {
                tableBody.innerHTML = `
                    <tr>
                        <td colspan="5" class="px-6 py-12 text-center text-gray-500">
                            <p class="text-lg font-medium text-gray-600 mb-2">No assigned tasks yet</p>
                            <p class="text-sm text-gray-500">Your organization will assign work here.</p>
                        </td>
                    </tr>`;
                return;
            }

            tableBody.innerHTML = tasks.map(task => `
                <tr class="border-b border-gray-100 hover:bg-gray-50 transition-colors">
                    <td class="px-6 py-4">
                        <div class="font-medium text-gray-900">${task.title || 'Untitled Task'}</div>
                        ${task.description ? `<div class="mt-1 text-xs text-gray-500">${task.description}</div>` : ''}
                    </td>
                    <td class="px-6 py-4 text-sm">
                        <span class="inline-flex rounded-full px-2 py-1 text-xs font-medium ${getPriorityClass(task.priority)}">${getPriorityText(task.priority)}</span>
                    </td>
                    <td class="px-6 py-4 text-sm text-gray-600">
                        ${task.dueDate ? new Date(task.dueDate).toLocaleDateString() : 'No due date'}
                    </td>
                    <td class="px-6 py-4 text-sm">
                        <span class="inline-flex rounded-full px-3 py-1 text-xs font-medium ${getStatusClass(task.status)}">${getStatusText(task.status)}</span>
                    </td>
                    <td class="px-6 py-4 text-sm">
                        <select onchange="updateTaskStatus(${task.id}, this.value)" class="rounded-lg border-0 px-2 py-1 text-xs font-medium cursor-pointer ${getStatusClass(task.status)}">
                            <option value="0" ${task.status === 0 ? 'selected' : ''}>Completed</option>
                            <option value="1" ${task.status === 1 ? 'selected' : ''}>In Progress</option>
                            <option value="2" ${task.status === 2 ? 'selected' : ''}>Pending</option>
                        </select>
                    </td>
                </tr>
            `).join('');
        }

        function updateStatistics(tasks) {
            document.getElementById('totalTasks').textContent = tasks.length;
            document.getElementById('completedTasks').textContent = tasks.filter(task => task.status === 0).length;
            document.getElementById('inProgressTasks').textContent = tasks.filter(task => task.status === 1).length;

            const today = new Date().toISOString().split('T')[0];
            document.getElementById('overdueTasks').textContent = tasks.filter(task => task.dueDate && task.dueDate < today && task.status !== 0).length;
        }

        function getPriorityText(priority) {
            switch (priority) {
                case 0: return 'Low';
                case 1: return 'Medium';
                case 2: return 'High';
                default: return 'Medium';
            }
        }

        function getPriorityClass(priority) {
            switch (priority) {
                case 0: return 'bg-emerald-100 text-emerald-800';
                case 1: return 'bg-amber-100 text-amber-800';
                case 2: return 'bg-rose-100 text-rose-800';
                default: return 'bg-gray-100 text-gray-800';
            }
        }

        function getStatusText(status) {
            switch (status) {
                case 0: return 'Completed';
                case 1: return 'In Progress';
                case 2: return 'Pending';
                default: return 'Pending';
            }
        }

        function getStatusClass(status) {
            switch (status) {
                case 0: return 'bg-emerald-100 text-emerald-800';
                case 1: return 'bg-blue-100 text-blue-800';
                case 2: return 'bg-gray-100 text-gray-800';
                default: return 'bg-gray-100 text-gray-800';
            }
        }

        async function updateTaskStatus(taskId, newStatus) {
            try {
                const response = await fetch(`${API_BASE}/tasks/${taskId}/status`, {
                    method: 'PATCH',
                    headers: getEmployeeHeaders(),
                    body: JSON.stringify({ status: parseInt(newStatus) })
                });

                const result = await response.json();

                if (result.success) {
                    showSuccess('Task status updated');
                    await loadEmployeeTasks();
                } else {
                    showError(result.message || 'Failed to update status');
                }
            }
            catch (error) {
                console.error('Error updating task status:', error);
                showError('Error updating task status');
            }
        }

        function setupEventListeners() {
            document.getElementById('taskSearch')?.addEventListener('input', function (e) {
                const searchTerm = e.target.value.toLowerCase();
                const filtered = employeeTasks.filter(task =>
                    (task.title || '').toLowerCase().includes(searchTerm) ||
                    (task.description && task.description.toLowerCase().includes(searchTerm))
                );
                displayTasks(filtered);
            });

            document.getElementById('taskFilter')?.addEventListener('change', function (e) {
                const status = e.target.value;
                let filtered = employeeTasks;

                if (status !== 'all') {
                    const statusMap = { pending: 2, inprogress: 1, completed: 0 };
                    filtered = employeeTasks.filter(task => task.status === statusMap[status]);
                }

                displayTasks(filtered);
            });
        }

        function showSuccess(message) {
            const toast = document.createElement('div');
            toast.className = 'fixed top-20 right-4 z-50 flex items-center gap-2 rounded-lg bg-green-500 px-6 py-3 text-white shadow-lg';
            toast.textContent = message;
            document.body.appendChild(toast);
            setTimeout(() => toast.remove(), 3000);
        }

        function showError(message) {
            const toast = document.createElement('div');
            toast.className = 'fixed top-20 right-4 z-50 flex items-center gap-2 rounded-lg bg-red-500 px-6 py-3 text-white shadow-lg';
            toast.textContent = message;
            document.body.appendChild(toast);
            setTimeout(() => toast.remove(), 5000);
        }

        async function submitNewPassword() {
            const tempPw = document.getElementById('tempPassword').value;
            const newPw = document.getElementById('newPassword').value;
            const confirmPw = document.getElementById('confirmPassword').value;
            const errorDiv = document.getElementById('pwError');

            errorDiv.classList.add('hidden');

            if (!tempPw || !newPw || !confirmPw) {
                errorDiv.textContent = 'All fields are required.';
                errorDiv.classList.remove('hidden');
                return;
            }
            if (newPw !== confirmPw) {
                errorDiv.textContent = 'Passwords do not match.';
                errorDiv.classList.remove('hidden');
                return;
            }
            if (newPw.length < 6) {
                errorDiv.textContent = 'Password must be at least 6 characters.';
                errorDiv.classList.remove('hidden');
                return;
            }
            if (!/^(?=.*[A-Z])(?=.*\d).+$/.test(newPw)) {
                errorDiv.textContent = 'Must contain at least one capital letter and one number.';
                errorDiv.classList.remove('hidden');
                return;
            }

            try {
                const response = await fetch('/Account/ChangePassword', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        currentPassword: tempPw,
                        newPassword: newPw,
                        confirmPassword: confirmPw
                    })
                });

                if (response.ok) {
                    document.getElementById('changePasswordModal').remove();
                    showSuccess('Password changed successfully');
                } else {
                    errorDiv.textContent = 'Failed. Please check your temporary password.';
                    errorDiv.classList.remove('hidden');
                }
            }
            catch {
                errorDiv.textContent = 'Connection error. Please try again.';
                errorDiv.classList.remove('hidden');
            }
        }
    </script>
}