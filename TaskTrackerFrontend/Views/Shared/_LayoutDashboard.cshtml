@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Smart Task Tracker</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Dashboard Specific Styles -->
    <style>
        :root {
            --background: #fafaf8;
            --foreground: #333333;
            --card: #ffffff;
            --primary: #2563eb;
            --primary-foreground: #ffffff;
            --secondary: #f5f5f4;
            --border: #e5e5e5;
            --muted: #f5f5f4;
            --muted-foreground: #737373;
            --destructive: #dc2626;
        }

        body {
            background-color: var(--background);
            color: var(--foreground);
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
        }

        .modal {
            display: none;
        }

            .modal.active {
                display: flex;
            }

        .status-badge {
            display: inline-block;
            padding: 0.25rem 0.75rem;
            border-radius: 9999px;
            font-size: 0.75rem;
            font-weight: 500;
            border: none;
            outline: none;
            cursor: pointer;
        }

        .status-completed {
            background-color: #dcfce7;
            color: #166534;
        }

        .status-inprogress {
            background-color: #dbeafe;
            color: #1e40af;
        }

        .status-pending {
            background-color: #f3f4f6;
            color: #374151;
        }

        .status-overdue {
            background-color: #fee2e2;
            color: #991b1b;
        }

        .priority-high {
            background-color: #fee2e2;
            color: #b91c1c;
        }

        .priority-medium {
            background-color: #fef3c7;
            color: #b45309;
        }

        .priority-low {
            background-color: #dcfce7;
            color: #166534;
        }

        table tr:hover {
            background-color: var(--muted);
        }

        .loading {
            opacity: 0.6;
            pointer-events: none;
        }

        /* Voice listening animation */
        .listening-animation {
            animation: pulse 1.5s infinite;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%) !important;
        }

        /* Notification bell animation */
        .notification-bounce {
            animation: bounce 0.5s ease-in-out;
        }

        @@keyframes pulse {
            0% {
                opacity: 1;
                transform: scale(1);
            }

            50% {
                opacity: 0.8;
                transform: scale(1.05);
            }

            100% {
                opacity: 1;
                transform: scale(1);
            }
        }

        @@keyframes bounce {
            0%, 100% {
                transform: translateY(0);
            }

            50% {
                transform: translateY(-10px);
            }
        }

        /* Notification panel styles */
        .notification-item {
            transition: background-color 0.2s;
        }

            .notification-item:hover {
                background-color: #f9fafb;
            }

        .notification-badge {
            animation: scale-in 0.3s ease-out;
        }

        @@keyframes scale-in {
            0% {
                transform: scale(0);
            }

            50% {
                transform: scale(1.2);
            }

            100% {
                transform: scale(1);
            }
        }
    </style>
    @RenderSection("Styles", required: false)
</head>
<body class="bg-gray-50">
    @{
        // Get current controller and action to determine active menu item
        var currentController = ViewContext.RouteData.Values["Controller"]?.ToString();
        var currentAction = ViewContext.RouteData.Values["Action"]?.ToString();
        var userRole = Context.Session.GetString("UserRole") ?? "User";
        var dashboardController = userRole == "Organization" ? "OrganizationDashboard" : (userRole == "Employee" ? "EmployeeDashboard" : "Dashboard");
    }

    <!-- Top Navigation Bar (Dashboard Version) -->
    <nav class="bg-white shadow-lg border-b border-gray-200 fixed top-0 left-0 right-0 z-40">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-16">
                <!-- Logo/Brand & Mobile Toggle -->
                <div class="flex items-center gap-4">
                    <button id="mobileMenuBtn" class="md:hidden text-gray-600 hover:text-blue-600 focus:outline-none">
                        <i class="fas fa-bars text-xl"></i>
                    </button>
                    <a href="@Url.Action("Index", dashboardController)" class="flex items-center gap-2 font-bold text-lg text-blue-600 hover:text-blue-700 transition">
                        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M9 2C7.89543 2 7 2.89543 7 4V20C7 21.1046 7.89543 22 9 22H21C22.1046 22 23 21.1046 23 20V4C23 2.89543 22.1046 2 21 2H9ZM9 4H21V20H9V4ZM10 7H20V9H10V7ZM10 11H20V13H10V11ZM10 15H20V17H10V15Z"></path>
                        </svg>
                        <span class="hidden sm:inline">Smart Task Tracker</span>
                    </a>
                </div>
                <!-- User Profile & Actions -->
                <div class="flex items-center gap-4">
                    <div class="flex items-center gap-2 text-gray-700">
                        <div class="w-8 h-8 bg-blue-600 rounded-full flex items-center justify-center text-white font-bold">
                            @Context.Session.GetString("UserName")?.Substring(0, 1)?.ToUpper()
                        </div>
                        <span>@Context.Session.GetString("UserName")</span>
                    </div>
                    <!-- Notification Bell -->
                    <button id="notificationBell" class="relative text-gray-700 hover:text-blue-600 transition-colors">
                        <i class="fas fa-bell text-xl"></i>
                        <span id="notificationCount" class="hidden absolute -top-1 -right-1 bg-red-500 text-white text-xs px-1.5 rounded-full min-w-[20px] h-5 flex items-center justify-center notification-badge">0</span>
                    </button>
                    <!-- Logout -->
                    <a asp-controller="Account" asp-action="Logout" class="flex items-center gap-2 text-gray-700 hover:text-red-600 transition-colors">
                        <i class="fas fa-sign-out-alt"></i>
                        <span>Logout</span>
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <!-- Notification Panel -->
    <div id="notificationPanel" class="hidden fixed top-16 right-4 w-96 bg-white border border-gray-200 rounded-lg shadow-xl z-50 max-h-[500px] overflow-hidden flex flex-col">
        <div class="p-4 border-b border-gray-200 bg-gradient-to-r from-blue-50 to-blue-100 flex items-center justify-between">
            <div class="flex items-center gap-2">
                <i class="fas fa-bell text-blue-600"></i>
                <h3 class="font-semibold text-gray-800">Task Notifications</h3>
            </div>
            <button id="clearAllNotifications" class="text-xs text-blue-600 hover:text-blue-800 font-medium">
                Clear All
            </button>
        </div>
        <div id="notificationList" class="overflow-y-auto flex-1">
            <!-- Notifications will be added here dynamically -->
        </div>
        <div id="noNotifications" class="p-8 text-center text-gray-500">
            <i class="fas fa-bell-slash text-3xl mb-2 opacity-50"></i>
            <p class="text-sm">No notifications yet</p>
        </div>
    </div>

    <div class="flex h-screen overflow-hidden pt-16">
        <!-- Sidebar with Dynamic Active Highlighting -->
        <aside id="sidebar" class="w-64 bg-white border-r border-gray-200 hidden md:block fixed md:relative h-full z-30 transition-transform transform -translate-x-full md:translate-x-0">
            <div class="p-6">
                <div class="flex items-center justify-between mb-8">
                    <div>
                        <h2 class="text-lg font-bold text-gray-800">Task Tracker</h2>
                        <span class="inline-flex rounded-full bg-blue-50 px-2 py-0.5 text-xs font-semibold text-blue-700 mt-1">@userRole</span>
                    </div>
                    <button id="closeSidebarBtn" class="md:hidden text-gray-500 hover:text-gray-800">
                        <i class="fas fa-times"></i>
                    </button>
                </div>
                <nav class="space-y-2">
                    @if (userRole == "Organization")
                    {
                        <a href="@Url.Action("Index", "OrganizationDashboard")"
                           class="block px-4 py-2 rounded-lg transition-colors @(currentController == "OrganizationDashboard" ? "bg-blue-50 text-blue-600 font-medium" : "text-gray-700 hover:bg-gray-50")">
                            <i class="fas fa-tachometer-alt mr-3"></i>Dashboard
                        </a>
                        <a href="@Url.Action("Index", "OrgEmployees")"
                           class="block px-4 py-2 rounded-lg transition-colors @(currentController == "OrgEmployees" && currentAction == "Index" ? "bg-blue-50 text-blue-600 font-medium" : "text-gray-700 hover:bg-gray-50")">
                            <i class="fas fa-users mr-3"></i>Employees
                        </a>
                        <a href="@Url.Action("Create", "OrgEmployees")"
                           class="block px-4 py-2 rounded-lg transition-colors @(currentController == "OrgEmployees" && currentAction == "Create" ? "bg-blue-50 text-blue-600 font-medium" : "text-gray-700 hover:bg-gray-50")">
                            <i class="fas fa-user-plus mr-3"></i>Add Employee
                        </a>
                    }
                    else if (userRole == "Employee")
                    {
                        <a href="@Url.Action("Index", "EmployeeDashboard")"
                           class="block px-4 py-2 rounded-lg transition-colors @(currentController == "EmployeeDashboard" ? "bg-blue-50 text-blue-600 font-medium" : "text-gray-700 hover:bg-gray-50")">
                            <i class="fas fa-tachometer-alt mr-3"></i>Dashboard
                        </a>
                    }
                    else
                    {
                        <a href="@Url.Action("Index", "Dashboard")"
                           class="block px-4 py-2 rounded-lg transition-colors @(currentController == "Dashboard" ? "bg-blue-50 text-blue-600 font-medium" : "text-gray-700 hover:bg-gray-50")">
                            <i class="fas fa-tachometer-alt mr-3"></i>Dashboard
                        </a>
                        <a href="@Url.Action("Index", "Tasks")"
                           class="block px-4 py-2 rounded-lg transition-colors @(currentController == "Tasks" && currentAction == "Index" ? "bg-blue-50 text-blue-600 font-medium" : "text-gray-700 hover:bg-gray-50")">
                            <i class="fas fa-tasks mr-3"></i>All Tasks
                        </a>
                        <a href="@Url.Action("Calendar", "Tasks")"
                           class="block px-4 py-2 rounded-lg transition-colors @(currentController == "Tasks" && currentAction == "Calendar" ? "bg-blue-50 text-blue-600 font-medium" : "text-gray-700 hover:bg-gray-50")">
                            <i class="fas fa-calendar mr-3"></i>Calendar
                        </a>
                    }
                    
                    <a href="@Url.Action("Index", "Settings")"
                       class="block px-4 py-2 rounded-lg transition-colors @(currentController == "Settings" ? "bg-blue-50 text-blue-600 font-medium" : "text-gray-700 hover:bg-gray-50")">
                        <i class="fas fa-cog mr-3"></i>Settings
                    </a>
                </nav>
            </div>
        </aside>

        <!-- Main Content Area -->
        <main class="flex-1 overflow-y-auto p-4 md:p-8">
            @RenderBody()
        </main>
    </div>

    <!-- Task Modal -->
    <div id="taskModal" class="modal fixed inset-0 bg-black/50 items-center justify-center z-50">
        <div class="bg-white rounded-lg shadow-lg w-full max-w-md border border-gray-200 mx-4">
            <div class="flex items-center justify-between p-6 border-b border-gray-200">
                <div class="flex items-center gap-3">
                    <h2 class="text-xl font-bold text-gray-800">Add New Task</h2>
                    <button type="button" onclick="startVoiceInput()" id="voiceButton"
                            class="ml-2 px-3 py-2 bg-gradient-to-r from-purple-500 to-pink-500 text-white rounded-lg hover:opacity-90 transition-all">
                        <i class="fas fa-microphone"></i>
                    </button>
                </div>
                <button onclick="closeModal()" class="p-1 hover:bg-gray-100 rounded-lg transition-colors">
                    <i class="fas fa-times text-lg text-gray-600"></i>
                </button>
            </div>
            <form id="addTaskForm" onsubmit="handleAddTask(event)" class="p-6 space-y-4" novalidate>
                <div class="bg-gradient-to-r from-purple-50 to-blue-50 p-4 rounded-lg border border-purple-200">
                    <div class="flex items-center justify-between mb-2">
                        <h3 class="font-medium text-purple-700">
                            <i class="fas fa-microphone mr-2"></i>Voice Command
                        </h3>
                        <span id="voiceStatus" class="text-sm text-gray-600"></span>
                    </div>
                    <p class="text-xs text-gray-600">
                        <i class="fas fa-lightbulb mr-1"></i>
                        <strong>Try saying:</strong> "Complete assignment priority high due tomorrow"
                    </p>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-800 mb-2">Task Name *</label>
                    <input type="text" id="taskName" placeholder="Enter task name or use voice command"
                           class="w-full px-4 py-2 border border-gray-300 rounded-lg bg-white text-gray-800 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-blue-600" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-800 mb-2">Description (Optional)</label>
                    <textarea id="taskDescription" placeholder="Enter task description"
                              class="w-full px-4 py-2 border border-gray-300 rounded-lg bg-white text-gray-800 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-blue-600"
                              rows="3"></textarea>
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-800 mb-2">Priority</label>
                        <select id="taskPriority" class="w-full px-4 py-2 border border-gray-300 rounded-lg bg-white text-gray-800 focus:outline-none focus:ring-2 focus:ring-blue-600">
                            <option value="0">Low</option>
                            <option value="1" selected>Medium</option>
                            <option value="2">High</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-800 mb-2">Status</label>
                        <select id="taskStatus" class="w-full px-4 py-2 border border-gray-300 rounded-lg bg-white text-gray-800 focus:outline-none focus:ring-2 focus:ring-blue-600">
                            <option value="2" selected>Pending</option>
                            @* <option value="1">In Progress</option> *@
                            @* <option value="0">Completed</option> *@
                        </select>
                    </div>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-800 mb-2">Due Date *</label>
                    <input type="date" id="taskDueDate"
                           class="w-full px-4 py-2 border border-gray-300 rounded-lg bg-white text-gray-800 focus:outline-none focus:ring-2 focus:ring-blue-600" />
                </div>
                <div class="flex gap-3 pt-4">
                    <button type="button" onclick="closeModal()"
                            class="flex-1 px-4 py-2 border border-gray-300 rounded-lg text-gray-800 hover:bg-gray-50 transition-colors font-medium">
                        Cancel
                    </button>
                    <button type="submit" id="addTaskButton"
                            class="flex-1 px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors font-medium">
                        <i class="fas fa-plus mr-2"></i>Add Task
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Hidden fields for user data -->
    <input type="hidden" id="userId" value="@Context.Session.GetInt32("UserId")" />
    <input type="hidden" id="userName" value="@Context.Session.GetString("UserName")" />
    <input type="hidden" id="userEmail" value="@Context.Session.GetString("UserEmail")" />
    <input type="hidden" id="userRole" value="@Context.Session.GetString("UserRole")" />
    <input type="hidden" id="authToken" value="@Context.Session.GetString("Token")" />

    <!-- SignalR Client Library -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

    <script>
        const API_BASE = 'https://localhost:7105/api';
        const userId = document.getElementById('userId')?.value;
        const userName = document.getElementById('userName')?.value;
        const userEmail = document.getElementById('userEmail')?.value;
        const userRole = document.getElementById('userRole')?.value;
        const authToken = document.getElementById('authToken')?.value;

        console.log('=== LAYOUT INITIALIZED ===');
        console.log('UserId:', userId);
        console.log('AuthToken exists:', !!authToken);

        function getAuthHeaders() {
            return {
                'Content-Type': 'application/json',
                'Authorization': `Bearer ${authToken}`
            };
        }

        if (!userId || !authToken) {
            console.error('No authentication, redirecting to login');
            window.location.href = '/Account/Login';
        }

        // ========== SIGNALR NOTIFICATION SETUP ==========
        let connection = null;
        let notifications = [];

        async function initializeSignalR() {
            try {
                console.log('=== Initializing SignalR Connection ===');

                connection = new signalR.HubConnectionBuilder()
                    .withUrl("https://localhost:7105/notificationHub", {
                        accessTokenFactory: () => authToken
                    })
                    .withAutomaticReconnect()
                    .configureLogging(signalR.LogLevel.Information)
                    .build();

                connection.on("ReceiveNotification", (notification) => {
                    console.log('✓ Received notification:', notification);
                    addNotification(notification);
                });

                connection.onreconnecting((error) => {
                    console.warn('⚠ SignalR reconnecting...', error);
                });

                connection.onreconnected((connectionId) => {
                    console.log('✓ SignalR reconnected:', connectionId);
                });

                connection.onclose((error) => {
                    console.error('❌ SignalR connection closed:', error);
                    setTimeout(() => initializeSignalR(), 5000);
                });

                await connection.start();
                console.log('✓ SignalR Connected Successfully');

            } catch (error) {
                console.error('❌ SignalR connection error:', error);
                setTimeout(() => initializeSignalR(), 5000);
            }
        }

        function addNotification(notification) {
            notifications.unshift({
                id: Date.now(),
                title: notification.title || 'Task Reminder',
                message: notification.message,
                timestamp: new Date()
            });

            updateNotificationUI();
            showNotificationToast(notification);

            const bell = document.getElementById('notificationBell');
            bell.classList.add('notification-bounce');
            setTimeout(() => bell.classList.remove('notification-bounce'), 500);
        }

        function updateNotificationUI() {
            const notificationList = document.getElementById('notificationList');
            const notificationCount = document.getElementById('notificationCount');
            const noNotifications = document.getElementById('noNotifications');

            if (notifications.length > 0) {
                notificationCount.textContent = notifications.length;
                notificationCount.classList.remove('hidden');
                noNotifications.classList.add('hidden');
            } else {
                notificationCount.classList.add('hidden');
                noNotifications.classList.remove('hidden');
            }

            notificationList.innerHTML = notifications.map(notif => `
                <div class="notification-item p-4 border-b border-gray-100 hover:bg-gray-50 transition-colors">
                    <div class="flex items-start gap-3">
                        <div class="flex-shrink-0 w-10 h-10 bg-blue-100 rounded-full flex items-center justify-center">
                            <i class="fas fa-bell text-blue-600"></i>
                        </div>
                        <div class="flex-1 min-w-0">
                            <h4 class="text-sm font-semibold text-gray-800 mb-1">${notif.title}</h4>
                            <p class="text-sm text-gray-600 mb-1">${notif.message}</p>
                            <p class="text-xs text-gray-400">${formatNotificationTime(notif.timestamp)}</p>
                        </div>
                        <button onclick="removeNotification(${notif.id})" class="flex-shrink-0 text-gray-400 hover:text-red-500 transition-colors">
                            <i class="fas fa-times"></i>
                        </button>
                    </div>
                </div>
            `).join('');
        }

        function removeNotification(id) {
            notifications = notifications.filter(n => n.id !== id);
            updateNotificationUI();
        }

        function clearAllNotifications() {
            notifications = [];
            updateNotificationUI();
            showSuccess('All notifications cleared');
        }

        function formatNotificationTime(timestamp) {
            const now = new Date();
            const diff = now - timestamp;
            const minutes = Math.floor(diff / 60000);

            if (minutes < 1) return 'Just now';
            if (minutes < 60) return `${minutes} minute${minutes > 1 ? 's' : ''} ago`;

            const hours = Math.floor(minutes / 60);
            if (hours < 24) return `${hours} hour${hours > 1 ? 's' : ''} ago`;

            const days = Math.floor(hours / 24);
            return `${days} day${days > 1 ? 's' : ''} ago`;
        }

        function showNotificationToast(notification) {
            const toast = document.createElement('div');
            toast.className = 'fixed top-20 right-4 bg-blue-500 text-white px-6 py-4 rounded-lg shadow-lg z-50 flex items-start gap-3 max-w-sm';
            toast.innerHTML = `
                <div class="flex-shrink-0">
                    <i class="fas fa-bell text-xl"></i>
                </div>
                <div class="flex-1">
                    <h4 class="font-semibold mb-1">${notification.title || 'Task Reminder'}</h4>
                    <p class="text-sm opacity-90">${notification.message}</p>
                </div>
                <button onclick="this.parentElement.remove()" class="flex-shrink-0 text-white/80 hover:text-white">
                    <i class="fas fa-times"></i>
                </button>
            `;

            document.body.appendChild(toast);

            setTimeout(() => {
                toast.style.opacity = '0';
                toast.style.transition = 'opacity 0.3s';
                setTimeout(() => toast.remove(), 300);
            }, 5000);
        }

        // ========== END SIGNALR NOTIFICATION SETUP ==========

        function openModal() {
            console.log('Opening add task modal');
            document.getElementById("taskModal").classList.add("active");
            const today = new Date();
            const tomorrow = new Date(today);
            tomorrow.setDate(tomorrow.getDate() + 1);
            document.getElementById("taskDueDate").min = today.toISOString().split('T')[0];
            document.getElementById("taskDueDate").value = tomorrow.toISOString().split('T')[0];
            const voiceStatus = document.getElementById('voiceStatus');
            voiceStatus.textContent = "Click microphone to use voice";
            voiceStatus.className = "text-sm text-gray-600";
            stopVoiceRecognition();
        }

        function closeModal() {
            console.log('Closing add task modal');
            document.getElementById("taskModal").classList.remove("active");
            document.getElementById("taskName").value = "";
            document.getElementById("taskDescription").value = "";
            document.getElementById("taskPriority").value = "1";
            document.getElementById("taskStatus").value = "2";
            document.getElementById("taskDueDate").value = "";
            const voiceStatus = document.getElementById('voiceStatus');
            voiceStatus.textContent = "";
            stopVoiceRecognition();
        }

        async function handleAddTask(event) {
            event.preventDefault();
            console.log('=== ADDING NEW TASK ===');

            const addButton = document.getElementById('addTaskButton');
            const originalText = addButton.innerHTML;

            // Get values
            const taskName = document.getElementById("taskName").value.trim();
            const taskDescription = document.getElementById("taskDescription").value.trim();
            const taskPriority = parseInt(document.getElementById("taskPriority").value);
            const taskStatus = parseInt(document.getElementById("taskStatus").value);
            const taskDueDate = document.getElementById("taskDueDate").value;

            // Manual validation
            if (!taskName) {
                showError('Task name is required');
                document.getElementById("taskName").focus();
                return;
            }

            if (!taskDueDate) {
                showError('Due date is required');
                document.getElementById("taskDueDate").focus();
                return;
            }

            try {
                addButton.disabled = true;
                addButton.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>Adding...';

                const newTask = {
                    Title: taskName,
                    Description: taskDescription || null,
                    DueDate: taskDueDate,
                    Priority: taskPriority,
                    Status: taskStatus,
                    UserId: parseInt(userId)
                };

                console.log('Sending task:', newTask);

                const response = await fetch(`${API_BASE}/tasks`, {
                    method: 'POST',
                    headers: getAuthHeaders(),
                    body: JSON.stringify(newTask)
                });

                console.log('Response status:', response.status);

                if (response.ok) {
                    const result = await response.json();
                    console.log('Task created:', result);
                    showSuccess('Task added successfully!');
                    closeModal();
                    if (typeof loadTasks === 'function') {
                        setTimeout(() => loadTasks(), 500);
                    } else if (typeof loadAllTasks === 'function') {
                        setTimeout(() => loadAllTasks(), 500);
                    } else {
                        setTimeout(() => window.location.reload(), 1000);
                    }
                } else {
                    const errorText = await response.text();
                    console.error('Error response:', errorText);
                    showError('Failed to add task. Please try again.');
                }
            } catch (error) {
                console.error('Error adding task:', error);
                showError('Network error: ' + error.message);
            } finally {
                addButton.disabled = false;
                addButton.innerHTML = originalText;
            }
        }

        function showSuccess(message) {
            const toast = document.createElement('div');
            toast.className = 'fixed top-20 right-4 bg-green-500 text-white px-6 py-3 rounded-lg shadow-lg z-50 flex items-center gap-2';
            toast.innerHTML = `<i class="fas fa-check-circle"></i><span>${message}</span>`;
            document.body.appendChild(toast);
            setTimeout(() => {
                toast.style.opacity = '0';
                toast.style.transition = 'opacity 0.3s';
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }

        function showError(message) {
            const toast = document.createElement('div');
            toast.className = 'fixed top-20 right-4 bg-red-500 text-white px-6 py-3 rounded-lg shadow-lg z-50 flex items-center gap-2';
            toast.innerHTML = `<i class="fas fa-exclamation-circle"></i><span>${message}</span>`;
            document.body.appendChild(toast);
            setTimeout(() => {
                toast.style.opacity = '0';
                toast.style.transition = 'opacity 0.3s';
                setTimeout(() => toast.remove(), 300);
            }, 5000);
        }

        // ========== VOICE RECOGNITION SETUP ==========
        let recognition = null;
        let isListening = false;

        function startVoiceInput() {
            console.log('=== STARTING VOICE INPUT ===');

            // Check browser support
            if (!('webkitSpeechRecognition' in window) && !('SpeechRecognition' in window)) {
                showError('Voice recognition is not supported in this browser. Please use Chrome, Edge, or Safari.');
                return;
            }

            const voiceButton = document.getElementById('voiceButton');
            const voiceStatus = document.getElementById('voiceStatus');

            // If already listening, stop
            if (isListening) {
                stopVoiceRecognition();
                return;
            }

            try {
                // Create recognition instance
                const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
                recognition = new SpeechRecognition();

                // Configure recognition
                recognition.lang = 'en-US';
                recognition.continuous = false;
                recognition.interimResults = false;
                recognition.maxAlternatives = 1;

                // Start listening
                recognition.start();
                isListening = true;

                // Update UI
                voiceButton.classList.add('listening-animation');
                voiceStatus.textContent = "Listening...";
                voiceStatus.className = "text-sm text-purple-600 font-medium";

                console.log('Voice recognition started');

                // Handle results
                recognition.onresult = (event) => {
                    const transcript = event.results[0][0].transcript;
                    console.log('Voice transcript:', transcript);

                    voiceStatus.textContent = "Processing...";
                    processVoiceCommand(transcript);
                };

                // Handle errors
                recognition.onerror = (event) => {
                    console.error('Voice recognition error:', event.error);

                    let errorMessage = 'Voice recognition error';
                    switch(event.error) {
                        case 'no-speech':
                            errorMessage = 'No speech detected. Please try again.';
                            break;
                        case 'audio-capture':
                            errorMessage = 'Microphone not found. Please check your device.';
                            break;
                        case 'not-allowed':
                            errorMessage = 'Microphone permission denied. Please allow microphone access.';
                            break;
                        case 'network':
                            errorMessage = 'Network error. Please check your connection.';
                            break;
                        default:
                            errorMessage = `Error: ${event.error}`;
                    }

                    showError(errorMessage);
                    stopVoiceRecognition();
                };

                // Handle end
                recognition.onend = () => {
                    console.log('Voice recognition ended');
                    stopVoiceRecognition();
                };

            } catch (error) {
                console.error('Error starting voice recognition:', error);
                showError('Failed to start voice recognition: ' + error.message);
                stopVoiceRecognition();
            }
        }

        function stopVoiceRecognition() {
            if (recognition && isListening) {
                try {
                    recognition.stop();
                } catch (e) {
                    console.error('Error stopping recognition:', e);
                }
            }

            const voiceButton = document.getElementById('voiceButton');
            const voiceStatus = document.getElementById('voiceStatus');

            voiceButton.classList.remove('listening-animation');
            voiceStatus.textContent = "Click microphone to use voice";
            voiceStatus.className = "text-sm text-gray-600";
            isListening = false;
            recognition = null;
        }

        function processVoiceCommand(transcript) {
            console.log('Processing voice command:', transcript);

            const lowerTranscript = transcript.toLowerCase();

            // Extract task name (everything before priority/due/status keywords)
            let taskName = transcript;
            const keywords = ['priority', 'due', 'status'];

            for (const keyword of keywords) {
                const index = lowerTranscript.indexOf(keyword);
                if (index !== -1) {
                    taskName = transcript.substring(0, index).trim();
                    break;
                }
            }

            // Set task name
            if (taskName) {
                document.getElementById('taskName').value = taskName;
            }

            // Extract priority
            if (lowerTranscript.includes('priority high') || lowerTranscript.includes('high priority')) {
                document.getElementById('taskPriority').value = '2';
            } else if (lowerTranscript.includes('priority low') || lowerTranscript.includes('low priority')) {
                document.getElementById('taskPriority').value = '0';
            } else if (lowerTranscript.includes('priority medium') || lowerTranscript.includes('medium priority')) {
                document.getElementById('taskPriority').value = '1';
            }

            // Extract status
            if (lowerTranscript.includes('status pending') || lowerTranscript.includes('pending')) {
                document.getElementById('taskStatus').value = '2';
            } else if (lowerTranscript.includes('status in progress') || lowerTranscript.includes('in progress')) {
                document.getElementById('taskStatus').value = '1';
            }

            // else if (lowerTranscript.includes('status completed') || lowerTranscript.includes('completed')) {
            //     document.getElementById('taskStatus').value = '0';
            // }

            // Extract due date
            const today = new Date();
            if (lowerTranscript.includes('due tomorrow') || lowerTranscript.includes('tomorrow')) {
                const tomorrow = new Date(today);
                tomorrow.setDate(tomorrow.getDate() + 1);
                document.getElementById('taskDueDate').value = tomorrow.toISOString().split('T')[0];
            } else if (lowerTranscript.includes('due today') || lowerTranscript.includes('today')) {
                document.getElementById('taskDueDate').value = today.toISOString().split('T')[0];
            } else if (lowerTranscript.includes('next week')) {
                const nextWeek = new Date(today);
                nextWeek.setDate(nextWeek.getDate() + 7);
                document.getElementById('taskDueDate').value = nextWeek.toISOString().split('T')[0];
            }

            // Update status
            const voiceStatus = document.getElementById('voiceStatus');
            voiceStatus.textContent = "Voice command processed!";
            voiceStatus.className = "text-sm text-green-600 font-medium";

            showSuccess('Voice command processed successfully!');

            setTimeout(() => {
                voiceStatus.textContent = "Click microphone to use voice";
                voiceStatus.className = "text-sm text-gray-600";
            }, 3000);
        }
        // ========== END VOICE RECOGNITION SETUP ==========

        document.addEventListener('DOMContentLoaded', function() {
            console.log('Layout DOM loaded');

            // Initialize SignalR connection
            initializeSignalR();

            // Modal click outside to close
            document.getElementById('taskModal')?.addEventListener('click', function(e) {
                if (e.target.id === 'taskModal') {
                    closeModal();
                }
            });

            // Notification bell toggle
            const notificationBell = document.getElementById('notificationBell');
            const notificationPanel = document.getElementById('notificationPanel');
            if (notificationBell && notificationPanel) {
                notificationBell.addEventListener('click', function(e) {
                    e.stopPropagation();
                    notificationPanel.classList.toggle('hidden');
                });
            }

            // Clear all notifications button
            const clearAllBtn = document.getElementById('clearAllNotifications');
            if (clearAllBtn) {
                clearAllBtn.addEventListener('click', clearAllNotifications);
            }

            // Click outside to close notification panel
            document.addEventListener('click', function(e) {
                if (notificationPanel && !notificationPanel.contains(e.target) &&
                    notificationBell && !notificationBell.contains(e.target)) {
                    notificationPanel.classList.add('hidden');
                }
            });

            // Mobile sidebar toggle
            const sidebar = document.getElementById('sidebar');
            const mobileMenuBtn = document.getElementById('mobileMenuBtn');
            const closeSidebarBtn = document.getElementById('closeSidebarBtn');

            if (sidebar && mobileMenuBtn) {
                mobileMenuBtn.addEventListener('click', () => {
                    sidebar.classList.remove('hidden');
                    sidebar.classList.remove('-translate-x-full');
                });
            }

            if (sidebar && closeSidebarBtn) {
                closeSidebarBtn.addEventListener('click', () => {
                    sidebar.classList.add('-translate-x-full');
                    setTimeout(() => sidebar.classList.add('hidden'), 300); // Wait for transition
                });
            }
        });
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>
