@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Smart Task Tracker</title>

    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- Font Awesome CDN -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <!-- Your Custom Styles -->
    <style>
        .hero-section {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        }

        .feature-icon {
            color: #667eea;
        }

        .custom-card {
            background: white;
            border-radius: 0.5rem;
            box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
            transition: all 0.3s ease;
        }

            .custom-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15);
            }

        .custom-btn {
            display: inline-block;
            font-weight: 500;
            line-height: 1.5;
            text-align: center;
            text-decoration: none;
            vertical-align: middle;
            cursor: pointer;
            user-select: none;
            border: 1px solid transparent;
            padding: 0.5rem 1rem;
            font-size: 1.125rem;
            border-radius: 0.5rem;
            transition: all 0.15s ease-in-out;
        }

        .custom-btn-light {
            color: #000;
            background-color: #f8f9fa;
            border-color: #f8f9fa;
        }

            .custom-btn-light:hover {
                background-color: #e2e6ea;
                border-color: #dae0e5;
            }

        .custom-btn-outline-light {
            color: #f8f9fa;
            border-color: #f8f9fa;
            background-color: transparent;
        }

            .custom-btn-outline-light:hover {
                color: #000;
                background-color: #f8f9fa;
            }

        .custom-btn-primary {
            color: #fff;
            background-color: #667eea;
            border-color: #667eea;
        }

            .custom-btn-primary:hover {
                background-color: #5a6fd8;
                border-color: #5a6fd8;
            }

        .custom-container {
            max-width: 1140px;
            margin-left: auto;
            margin-right: auto;
            padding-left: 1rem;
            padding-right: 1rem;
        }

        .bg-light {
            background-color: #f8f9fa !important;
        }

        .text-primary {
            color: #667eea !important;
        }
    </style>
</head>
<body class="bg-gray-50">

    <!-- Navigation Bar -->
    <nav class="fixed top-0 w-full bg-white shadow-md z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-16">
                <!-- Logo -->
                <a asp-controller="Home" asp-action="Index" class="flex items-center gap-2 font-bold text-lg text-blue-600 hover:text-blue-700 transition">
                    <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M9 2C7.89543 2 7 2.89543 7 4V20C7 21.1046 7.89543 22 9 22H21C22.1046 22 23 21.1046 23 20V4C23 2.89543 22.1046 2 21 2H9ZM9 4H21V20H9V4ZM10 7H20V9H10V7ZM10 11H20V13H10V11ZM10 15H20V17H10V15Z"></path>
                    </svg>
                    Smart Task Tracker
                </a>

                <!-- Mobile Menu Button -->
                <button class="md:hidden p-2 rounded-lg hover:bg-gray-100" id="mobile-menu-btn">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
                    </svg>
                </button>

                <!-- Desktop Links -->
                <ul class="hidden md:flex items-center gap-8">
                    <li>
                        <a asp-controller="Home" asp-action="Index" class="text-blue-600 font-medium transition">Home</a>
                    </li>
                    <li>
                        <a asp-controller="Home" asp-action="About" class="text-gray-700 hover:text-blue-600 font-medium transition">About</a>
                    </li>
                    <li>
                        <a asp-controller="Account" asp-action="Login" class="text-gray-700 hover:text-blue-600 font-medium transition">Login</a>
                    </li>
                    <li>
                        <a asp-controller="Account" asp-action="Register" class="text-gray-700 hover:text-blue-600 font-medium transition">Register</a>
                    </li>
                </ul>
            </div>

            <!-- Mobile Menu -->
            <div id="mobile-menu" class="hidden md:hidden pb-4 pt-2 border-t border-gray-200">
                <ul class="flex flex-col gap-3">
                    <li>
                        <a asp-controller="Home" asp-action="Index" class="block px-4 py-2 text-blue-600 bg-blue-50 rounded-lg transition">Home</a>
                    </li>
                    <li>
                        <a asp-controller="Home" asp-action="About" class="block px-4 py-2 text-gray-700 hover:bg-gray-100 rounded-lg transition">About</a>
                    </li>
                    <li>
                        <a asp-controller="Account" asp-action="Login" class="block px-4 py-2 text-gray-700 hover:bg-gray-100 rounded-lg transition">Login</a>
                    </li>
                    <li>
                        <a asp-controller="Account" asp-action="Register" class="block px-4 py-2 text-gray-700 hover:bg-gray-100 rounded-lg transition">Register</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Main Content Area -->
    <main class="pt-20">
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="bg-gray-800 text-white py-8">
        <div class="custom-container text-center">
            <p>&copy; @DateTime.Now.Year Smart Task Tracker. All rights reserved.</p>
        </div>
    </footer>

    <!-- Mobile Menu Script -->
    <script>
        document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
            document.getElementById('mobile-menu')?.classList.toggle('hidden');
        });
    </script>

    @RenderSection("Scripts", required: false)

</body>
</html>