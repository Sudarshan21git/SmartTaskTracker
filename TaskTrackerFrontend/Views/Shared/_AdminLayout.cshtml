<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Admin | Smart Task Tracker</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body class="bg-gray-100">
    <!-- Admin Nav Bar -->
    <nav class="fixed top-0 w-full bg-white shadow-lg z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-16">
                <div class="flex items-center gap-3">
                    <svg class="w-8 h-8 text-blue-600" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M9 2C7.89543 2 7 2.89543 7 4V20C7 21.1046 7.89543 22 9 22H21C22.1046 22 23 21.1046 23 20V4C23 2.89543 22.1046 2 21 2H9ZM9 4H21V20H9V4ZM10 7H20V9H10V7ZM10 11H20V13H10V11ZM10 15H20V17H10V15Z"></path>
                    </svg>
                    <span class="text-xl font-bold text-blue-600">Smart Task Tracker</span>
                    <span class="text-sm text-gray-500 ml-2">Admin Panel</span>
                </div>

                <div class="flex items-center gap-6">
                    <div class="text-right">
                        <p class="text-sm font-medium text-gray-900">Welcome, @User.Identity!.Name</p>
                        <p class="text-xs text-gray-500">Administrator</p>
                    </div>
                    <a asp-controller="Account" asp-action="Logout" class="text-red-600 hover:text-red-700 font-medium">
                        Logout
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <main class="pt-20 min-h-screen p-8">
        <div class="max-w-7xl mx-auto">
            @RenderBody()
        </div>
    </main>

    <script>
        const API_BASE = 'https://localhost:7105/api';
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>