@model TaskTrackerFrontend.Models.LoginModel
@{
    ViewData["Title"] = "Login";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="min-h-screen flex bg-gray-50 text-gray-900 pt-16">
    <!-- Left Side - Branding Panel (hidden on mobile) -->
    <div class="hidden lg:flex lg:w-1/2 bg-gradient-to-br from-blue-600 to-blue-800 flex-col justify-between p-12">
        <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-white rounded-lg flex items-center justify-center">
                <span class="text-blue-600 font-bold text-lg">✓</span>
            </div>
            <h1 class="text-2xl font-bold text-white">Smart Task Tracker</h1>
        </div>
        <div>
            <h2 class="text-4xl font-bold text-white mb-6">Organize your work.</h2>
            <p class="text-blue-100 text-lg mb-8">
                Stay on top of your tasks, collaborate with your team, and deliver projects on time. Smart Task Tracker makes productivity effortless.
            </p>
            <ul class="space-y-4">
                <li class="flex items-center gap-3 text-white">
                    <span class="w-5 h-5 bg-white/30 rounded-full flex items-center justify-center text-sm">✓</span>
                    Real-time task updates
                </li>
                <li class="flex items-center gap-3 text-white">
                    <span class="w-5 h-5 bg-white/30 rounded-full flex items-center justify-center text-sm">✓</span>
                    Team collaboration features
                </li>
                <li class="flex items-center gap-3 text-white">
                    <span class="w-5 h-5 bg-white/30 rounded-full flex items-center justify-center text-sm">✓</span>
                    Smart scheduling & reminders
                </li>
            </ul>
        </div>
        <p class="text-blue-100 text-sm">© 2025 Smart Task Tracker. All rights reserved.</p>
    </div>

    <!-- Right Side - Login Form -->
    <div class="w-full lg:w-1/2 flex items-center justify-center p-8">
        <div class="w-full max-w-md">
            <!-- Mobile Header -->
            <div class="lg:hidden mb-8 text-center">
                <div class="flex items-center justify-center gap-2 mb-4">
                    <div class="w-10 h-10 bg-blue-600 rounded-lg flex items-center justify-center">
                        <span class="text-white font-bold text-lg">✓</span>
                    </div>
                    <h1 class="text-2xl font-bold">Smart Task Tracker</h1>
                </div>
            </div>

            <h2 class="text-3xl font-bold mb-2">Welcome back</h2>
            <p class="text-gray-600 mb-8">Sign in to your account to continue</p>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="p-4 mb-6 rounded-lg bg-red-50 text-red-800 border border-red-200">
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <p>@error.ErrorMessage</p>
                    }
                </div>
            }

            <form asp-action="Login" method="post" class="space-y-5">
                @Html.AntiForgeryToken()

                <div>
                    <label asp-for="Email" class="block text-sm font-medium mb-2"></label>
                    <input asp-for="Email" type="email" placeholder="you@example.com"
                           class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent bg-white" />
                    <span asp-validation-for="Email" class="text-red-600 text-sm"></span>
                </div>

                <div>
                    <label asp-for="Password" class="block text-sm font-medium mb-2"></label>
                    <input asp-for="Password" type="password" placeholder="••••••••"
                           class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent bg-white" />
                    <span asp-validation-for="Password" class="text-red-600 text-sm"></span>
                </div>

                <button type="submit"
                        class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 rounded-lg transition-colors duration-200 mt-8">
                    Sign in
                </button>
            </form>

            <p class="text-center mt-8 text-sm">
                Don't have an account?
                <a asp-controller="Account" asp-action="Register" class="text-blue-600 hover:text-blue-700 font-semibold ml-1">
                    Sign up for free
                </a>
            </p>
        </div>
    </div>
</div>